      "Bash(python -m pytest tests/test_v7154_fixes.py -v --tb=short)",
      "Bash(python -c \"\nfrom intelligent_project_analyzer.services.search_filter_manager import SearchFilterManager, get_filter_manager\n\nprint\\(''='' * 60\\)\nprint\\(''SearchFilterManager 空值处理修复 - 完整测试''\\)\nprint\\(''='' * 60\\)\n\n# 测试 1: 正常配置文件加载\nprint\\(''\\\\n[测试 1] 正常配置文件加载''\\)\nmanager = SearchFilterManager\\(register_global=False\\)\nconfig = manager.get_config\\(\\)\nstats = manager.get_statistics\\(\\)\nprint\\(f''  ✓ 配置加载成功''\\)\nprint\\(f''  ✓ 黑名单: {stats[\"\"blacklist\"\"][\"\"total\"\"]} 条规则''\\)\nprint\\(f''  ✓ 白名单: {stats[\"\"whitelist\"\"][\"\"total\"\"]} 条规则''\\)\n\n# 测试 2: 模拟空配置（None 值）\nprint\\(''\\\\n[测试 2] 模拟空配置（所有字段为 None）''\\)\nmanager2 = SearchFilterManager\\(register_global=False\\)\nmanager2._config = {''blacklist'': None, ''whitelist'': None, ''metadata'': None, ''scope'': None}\n\nerrors = []\ntry:\n    config2 = manager2.get_config\\(\\)\n    print\\(f''  ✓ get_config\\(\\) 成功''\\)\nexcept Exception as e:\n    errors.append\\(f''get_config\\(\\): {e}''\\)\n\ntry:\n    stats2 = manager2.get_statistics\\(\\)\n    print\\(f''  ✓ get_statistics\\(\\) 成功''\\)\nexcept Exception as e:\n    errors.append\\(f''get_statistics\\(\\): {e}''\\)\n\ntry:\n    enabled = manager2.is_enabled\\(\\)\n    print\\(f''  ✓ is_enabled\\(\\) 成功: {enabled}''\\)\nexcept Exception as e:\n    errors.append\\(f''is_enabled\\(\\): {e}''\\)\n\ntry:\n    result = manager2.is_blacklisted\\(''https://test.com''\\)\n    print\\(f''  ✓ is_blacklisted\\(\\) 成功: {result}''\\)\nexcept Exception as e:\n    errors.append\\(f''is_blacklisted\\(\\): {e}''\\)\n\ntry:\n    result = manager2.is_whitelisted\\(''https://test.com''\\)\n    print\\(f''  ✓ is_whitelisted\\(\\) 成功: {result}''\\)\nexcept Exception as e:\n    errors.append\\(f''is_whitelisted\\(\\): {e}''\\)\n\nif errors:\n    print\\(f''  ✗ 失败: {errors}''\\)\n\n# 测试 3: 黑白名单检查功能\nprint\\(''\\\\n[测试 3] 黑白名单检查功能''\\)\nmanager3 = get_filter_manager\\(\\)\ntest_cases = [\n    \\(''https://archdaily.com/article/123'', False, True, ''白名单域名''\\),\n    \\(''https://example-spam.com/page'', True, False, ''黑名单域名''\\),\n    \\(''https://unknown-site.com/test'', False, False, ''未知域名''\\),\n    \\(''https://gooood.cn/project/456'', False, True, ''白名单域名''\\),\n]\n\nall_passed = True\nfor url, expected_black, expected_white, desc in test_cases:\n    is_black = manager3.is_blacklisted\\(url\\)\n    is_white = manager3.is_whitelisted\\(url\\)\n    passed = \\(is_black == expected_black and is_white == expected_white\\)\n    status = ''✓'' if passed else ''✗''\n    print\\(f''  {status} {desc}: {url}''\\)\n    if not passed:\n        print\\(f''      期望: 黑={expected_black}, 白={expected_white}''\\)\n        print\\(f''      实际: 黑={is_black}, 白={is_white}''\\)\n        all_passed = False\n\n# 测试 4: API 端点模拟\nprint\\(''\\\\n[测试 4] 模拟 API 端点调用''\\)\ntry:\n    manager4 = get_filter_manager\\(\\)\n    config = manager4.get_config\\(\\)\n    stats = manager4.get_statistics\\(\\)\n    \n    # 模拟 admin_routes.py 中的响应结构\n    response = {\n        ''status'': ''success'',\n        ''data'': {\n            ''blacklist'': config.get\\(''blacklist'', {}\\),\n            ''whitelist'': config.get\\(''whitelist'', {}\\),\n            ''scope'': config.get\\(''scope'', {}\\),\n            ''metadata'': config.get\\(''metadata'', {}\\),\n            ''statistics'': stats,\n        },\n    }\n    print\\(f''  ✓ API 响应构建成功''\\)\n    print\\(f''  ✓ 黑名单域名数: {len\\(response[\"\"data\"\"][\"\"blacklist\"\"].get\\(\"\"domains\"\", []\\)\\)}''\\)\n    print\\(f''  ✓ 白名单域名数: {len\\(response[\"\"data\"\"][\"\"whitelist\"\"].get\\(\"\"domains\"\", []\\)\\)}''\\)\nexcept Exception as e:\n    print\\(f''  ✗ API 响应构建失败: {e}''\\)\n\nprint\\(''\\\\n'' + ''='' * 60\\)\nprint\\(''测试完成!''\\)\nprint\\(''='' * 60\\)\n\")",
      "Bash(python -m pytest tests/test_search_filter_manager.py -v --tb=short)",
      "Bash(python -c \"\nimport yaml\nfrom pathlib import Path\n\nconfig_path = Path\\(''intelligent_project_analyzer/config/prompts/dynamic_project_director_v2.yaml''\\)\nwith open\\(config_path, ''r'', encoding=''utf-8''\\) as f:\n    config = yaml.safe_load\\(f\\)\n\nprint\\(''Top-level keys:'', list\\(config.keys\\(\\)\\)\\)\nif ''scenario_rules'' in config:\n    print\\(''scenario_rules keys:'', list\\(config[''scenario_rules''].keys\\(\\)\\)\\)\n    if ''special_population'' in config[''scenario_rules'']:\n        print\\(''special_population:'', config[''scenario_rules''][''special_population'']\\)\n\")",
      "Bash(more +1)",
      "Bash(python -c \"\nimport sys\nsys.path.insert\\(0, ''d:/11-20/langgraph-design''\\)\nfrom intelligent_project_analyzer.services.redis_session_manager import RedisSessionManager\n\nmanager = RedisSessionManager\\(\\)\nsession_id = ''8pdwoxj8-20260108092619-1cc10316''\n\n# Get session data\ndata = manager.get_session\\(session_id\\)\nif data:\n    # Extract search references\n    refs = data.get\\(''search_references'', []\\)\n    print\\(f''Total search references: {len\\(refs\\)}''\\)\n    print\\(\\)\n    \n    # Analyze quality issues\n    issues = {\n        ''placeholder_urls'': [],\n        ''missing_urls'': [],\n        ''low_quality'': [],\n        ''low_relevance'': [],\n        ''old_content'': []\n    }\n    \n    for ref in refs:\n        url = ref.get\\(''url'', ''''\\)\n        \n        # Check for placeholder URLs\n        if url and any\\(p in url.lower\\(\\) for p in [''example.com'', ''placeholder'', ''test.com'']\\):\n            issues[''placeholder_urls''].append\\(ref\\)\n        \n        # Check for missing URLs\n        if not url or url == ''None'':\n            issues[''missing_urls''].append\\(ref\\)\n        \n        # Check quality score\n        quality = ref.get\\(''quality_score'', 0\\)\n        if quality and quality < 70:\n            issues[''low_quality''].append\\(ref\\)\n        \n        # Check relevance\n        relevance = ref.get\\(''relevance_score'', 0\\)\n        if relevance < 0.7:\n            issues[''low_relevance''].append\\(ref\\)\n    \n    # Print summary\n    for issue_type, items in issues.items\\(\\):\n        if items:\n            print\\(f''{issue_type}: {len\\(items\\)} items''\\)\n            for item in items[:3]:  # Show first 3\n                print\\(f''  - {item.get\\(\"\"title\"\", \"\"N/A\"\"\\)[:50]}''\\)\n                print\\(f''    URL: {item.get\\(\"\"url\"\", \"\"N/A\"\"\\)}''\\)\n                print\\(f''    Tool: {item.get\\(\"\"source_tool\"\", \"\"N/A\"\"\\)}''\\)\n                print\\(\\)\nelse:\n    print\\(''Session not found''\\)\n\")",
      "Bash(python -c \"\nimport sys\nimport asyncio\nsys.path.insert\\(0, ''d:/11-20/langgraph-design''\\)\nfrom intelligent_project_analyzer.services.redis_session_manager import RedisSessionManager\n\nasync def analyze\\(\\):\n    manager = RedisSessionManager\\(\\)\n    await manager.connect\\(\\)\n    \n    session_id = ''8pdwoxj8-20260108092619-1cc10316''\n    \n    # Get session data\n    data = await manager.get\\(session_id\\)\n    if data:\n        # Extract search references\n        refs = data.get\\(''search_references'', []\\)\n        print\\(f''Total search references: {len\\(refs\\)}''\\)\n        print\\(\\)\n        \n        # Analyze quality issues\n        issues = {\n            ''placeholder_urls'': [],\n            ''missing_urls'': [],\n            ''low_quality'': [],\n            ''low_relevance'': [],\n        }\n        \n        for ref in refs:\n            url = ref.get\\(''url'', ''''\\)\n            \n            # Check for placeholder URLs\n            if url and any\\(p in url.lower\\(\\) for p in [''example.com'', ''placeholder'', ''test.com'']\\):\n                issues[''placeholder_urls''].append\\(ref\\)\n            \n            # Check for missing URLs\n            if not url or url == ''None'':\n                issues[''missing_urls''].append\\(ref\\)\n            \n            # Check quality score\n            quality = ref.get\\(''quality_score'', 0\\)\n            if quality and quality < 70:\n                issues[''low_quality''].append\\(ref\\)\n            \n            # Check relevance\n            relevance = ref.get\\(''relevance_score'', 0\\)\n            if relevance < 0.7:\n                issues[''low_relevance''].append\\(ref\\)\n        \n        # Print summary\n        for issue_type, items in issues.items\\(\\):\n            if items:\n                print\\(f''{issue_type}: {len\\(items\\)} items''\\)\n                for item in items[:2]:  # Show first 2\n                    print\\(f''  - {item.get\\(\"\"title\"\", \"\"N/A\"\"\\)[:60]}''\\)\n                    print\\(f''    URL: {item.get\\(\"\"url\"\", \"\"N/A\"\"\\)}''\\)\n                    print\\(f''    Tool: {item.get\\(\"\"source_tool\"\", \"\"N/A\"\"\\)}''\\)\n                    print\\(f''    Quality: {item.get\\(\"\"quality_score\"\", \"\"N/A\"\"\\)}''\\)\n                    print\\(f''    Relevance: {item.get\\(\"\"relevance_score\"\", \"\"N/A\"\"\\)}''\\)\n                    print\\(\\)\n    else:\n        print\\(''Session not found''\\)\n    \n    await manager.disconnect\\(\\)\n\nasyncio.run\\(analyze\\(\\)\\)\n\")",
