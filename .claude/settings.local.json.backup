      "Bash(python -c \"\n# 测试 P0-1: 交付物责任者映射\nfrom intelligent_project_analyzer.workflow.nodes.deliverable_id_generator_node import _build_full_owner_role\n\nprint\\(''=== P0-1: 交付物责任者映射测试 ===''\\)\n\n# 测试1: 字典格式\nselected_roles = [\n    {''role_id'': ''2-1'', ''dynamic_role_name'': ''设计总监''},\n    {''role_id'': ''3-1'', ''dynamic_role_name'': ''叙事专家''},\n]\nresult = _build_full_owner_role\\(''2-1'', selected_roles\\)\nprint\\(f''字典格式测试: 2-1 -> {result}''\\)\nassert result == ''V2_设计总监_2-1'', f''期望 V2_设计总监_2-1, 实际 {result}''\n\n# 测试2: 字符串格式\nselected_roles = [''2-1'', ''3-1'']\nresult = _build_full_owner_role\\(''2-1'', selected_roles\\)\nprint\\(f''字符串格式测试: 2-1 -> {result}''\\)\nassert result == ''V2_专家_2-1'', f''期望 V2_专家_2-1, 实际 {result}''\n\n# 测试3: 回退逻辑\nresult = _build_full_owner_role\\(''5-2'', []\\)\nprint\\(f''回退逻辑测试: 5-2 -> {result}''\\)\nassert result == ''V5_专家_5-2'', f''期望 V5_专家_5-2, 实际 {result}''\n\nprint\\(''✅ P0-1 测试通过!''\\)\n\")",
      "Bash(python -m pytest tests/test_bocha_quality_control.py -v --tb=short)",
      "Bash(python -c \"\n# 测试 P0-2: 审核问题整改流程\nfrom intelligent_project_analyzer.interaction.nodes.analysis_review import AnalysisReviewNode\n\nprint\\(''=== P0-2: 审核问题整改流程测试 ===''\\)\n\n# 测试1: 从 recommendations 中提取专家ID\nreview_result = {\n    ''recommendations'': {\n        ''recommendations'': [\n            {''source_expert'': ''V2_设计总监_2-1'', ''content'': ''设计建议''},\n            {''source_expert'': ''V4_研究专家_4-1'', ''content'': ''研究建议''},\n        ]\n    },\n    ''red_team_review'': {''issues'': []},\n    ''client_review'': {''accepted_improvements'': []},\n}\n\nagents = AnalysisReviewNode._extract_agents_from_issues\\([], review_result\\)\nprint\\(f''从 recommendations 提取: {agents}''\\)\nassert ''V2'' in agents, ''V2 应该被提取''\nassert ''V4'' in agents, ''V4 应该被提取''\n\n# 测试2: 从 client_decisions 描述中提取专家ID\nreview_result = {\n    ''recommendations'': {''recommendations'': []},\n    ''red_team_review'': {''issues'': []},\n    ''client_review'': {\n        ''accepted_improvements'': [\n            {''description'': ''未提供传统园林美学与现代高端住宅实际案例的融合实践路径''},\n            {''description'': ''文化叙事与符号转译未形成清晰的设计框架''},\n            {''description'': ''未明确针对传统园林中的连廊结构适用现代住宅的技术改良方式''},\n        ]\n    },\n}\n\nagents = AnalysisReviewNode._extract_agents_from_issues\\([], review_result\\)\nprint\\(f''从 client_decisions 提取: {agents}''\\)\n# 应该从描述中提取到专家: 案例->V4, 叙事->V3, 技术->V6\nassert len\\(agents\\) > 0, ''应该提取到至少一个专家''\n\nprint\\(''✅ P0-2 测试通过!''\\)\n\")",
      "Bash(python -c \"\n# 测试 P1-1: 专家分布统计\nfrom intelligent_project_analyzer.report.result_aggregator import ResultAggregatorAgent\n\nprint\\(''=== P1-1: 专家分布统计测试 ===''\\)\n\nagent = ResultAggregatorAgent\\(llm_model=None\\)\n\n# 测试1: 短格式 role_id\nagent_results = {\n    ''2-1'': {''content'': ''设计内容''},\n    ''3-1'': {''content'': ''叙事内容''},\n    ''4-1'': {''content'': ''研究内容''},\n    ''requirements_analyst'': {''content'': ''需求分析''},\n}\n\ndistribution = agent._get_expert_distribution\\(agent_results\\)\nprint\\(f''短格式测试: {distribution}''\\)\nassert distribution.get\\(''V2_设计总监'', 0\\) == 1, ''V2 应该有1个''\nassert distribution.get\\(''V3_领域专家'', 0\\) == 1, ''V3 应该有1个''\nassert distribution.get\\(''V4_研究专家'', 0\\) == 1, ''V4 应该有1个''\n\n# 测试2: 完整格式 role_id\nagent_results = {\n    ''V2_设计总监_2-1'': {''content'': ''设计内容''},\n    ''V3_叙事专家_3-1'': {''content'': ''叙事内容''},\n    ''V5_场景专家_5-1'': {''content'': ''场景内容''},\n    ''V6_工程师_6-1'': {''content'': ''工程内容''},\n}\n\ndistribution = agent._get_expert_distribution\\(agent_results\\)\nprint\\(f''完整格式测试: {distribution}''\\)\nassert distribution.get\\(''V2_设计总监'', 0\\) == 1, ''V2 应该有1个''\nassert distribution.get\\(''V3_领域专家'', 0\\) == 1, ''V3 应该有1个''\nassert distribution.get\\(''V5_创新专家'', 0\\) == 1, ''V5 应该有1个''\nassert distribution.get\\(''V6_实施专家'', 0\\) == 1, ''V6 应该有1个''\n\n# 测试3: V7 支持\nagent_results = {\n    ''V7_情感专家_7-1'': {''content'': ''情感分析''},\n    ''7-2'': {''content'': ''情感内容''},\n}\n\ndistribution = agent._get_expert_distribution\\(agent_results\\)\nprint\\(f''V7支持测试: {distribution}''\\)\nassert distribution.get\\(''V7_情感专家'', 0\\) == 2, ''V7 应该有2个''\n\nprint\\(''✅ P1-1 测试通过!''\\)\n\")",
      "Bash(python -m pytest tests/test_bocha_quality_control.py -v --tb=line)",
      "Bash(python -c \"\n# 测试 P2-2: 置信度校准参数\nfrom intelligent_project_analyzer.agents.task_oriented_expert_factory import TaskOrientedExpertFactory\nfrom unittest.mock import MagicMock\n\nprint\\(''=== P2-2: 置信度校准参数测试 ===''\\)\n\nfactory = TaskOrientedExpertFactory\\(llm_model=MagicMock\\(\\)\\)\n\n# 测试1: 短内容应该被惩罚，但惩罚更温和\nshort_content_output = {\n    ''task_execution_report'': {\n        ''deliverable_outputs'': [\n            {\n                ''deliverable_name'': ''测试交付物'',\n                ''content'': ''短内容'',  # 很短\n                ''quality_self_assessment'': 0.95\n            }\n        ]\n    }\n}\n\nresult = factory._calibrate_quality_scores\\(short_content_output, recorder=None\\)\ncalibrated_score = result[''task_execution_report''][''deliverable_outputs''][0][''quality_self_assessment'']\nprint\\(f''短内容校准: 0.95 -> {calibrated_score}''\\)\n\n# 新惩罚: 内容过短 0.10 + 缺少引用 0.05 + 缺少案例 0.03 + 缺少数据 0.02 = 0.20\n# 预期: 0.95 - 0.20 = 0.75\nassert calibrated_score >= 0.70, f''校准后分数 {calibrated_score} 应该 >= 0.70''\nassert calibrated_score <= 0.80, f''校准后分数 {calibrated_score} 应该 <= 0.80''\n\n# 测试2: 最低分应该是 0.6\nvery_low_output = {\n    ''task_execution_report'': {\n        ''deliverable_outputs'': [\n            {\n                ''deliverable_name'': ''测试交付物'',\n                ''content'': ''短'',\n                ''quality_self_assessment'': 0.65\n            }\n        ]\n    }\n}\n\nresult = factory._calibrate_quality_scores\\(very_low_output, recorder=None\\)\ncalibrated_score = result[''task_execution_report''][''deliverable_outputs''][0][''quality_self_assessment'']\nprint\\(f''低分校准: 0.65 -> {calibrated_score}''\\)\nassert calibrated_score >= 0.6, f''最低分应该是 0.6, 实际 {calibrated_score}''\n\n# 测试3: 优质内容惩罚应该较小\ngood_content = ''''''\n这是一个详细的分析报告，包含多个案例研究。\n\n案例1：拙政园的连廊设计\n根据研究数据显示，传统园林连廊的宽度通常在1.2-1.5米之间。\n统计表明，约80%的游客更喜欢有遮阳功能的连廊设计。\n\n案例2：留园的空间布局\n例如，留园的曲廊设计采用了\"移步换景\"的手法。\n调研发现，这种设计能够增加30%的空间感知深度。\n'''''' * 3\n\ngood_content_output = {\n    ''task_execution_report'': {\n        ''deliverable_outputs'': [\n            {\n                ''deliverable_name'': ''测试交付物'',\n                ''content'': good_content,\n                ''quality_self_assessment'': 0.95\n            }\n        ]\n    }\n}\n\nresult = factory._calibrate_quality_scores\\(good_content_output, recorder=None\\)\ncalibrated_score = result[''task_execution_report''][''deliverable_outputs''][0][''quality_self_assessment'']\nprint\\(f''优质内容校准: 0.95 -> {calibrated_score}''\\)\n# 优质内容只有搜索引用惩罚 0.05\nassert calibrated_score >= 0.85, f''优质内容不应被过度惩罚，实际评分: {calibrated_score}''\n\nprint\\(''✅ P2-2 测试通过!''\\)\n\")",
      "Bash(python -m pytest tests/test_bocha_quality_control.py -v --tb=line -q)",
      "Bash(python -c \"\n# 测试 P2-2: 置信度校准参数\nfrom intelligent_project_analyzer.agents.task_oriented_expert_factory import TaskOrientedExpertFactory\n\nprint\\(''=== P2-2: 置信度校准参数测试 ===''\\)\n\n# 使用 __new__ 创建实例，避免 __init__ 参数问题\nfactory = TaskOrientedExpertFactory.__new__\\(TaskOrientedExpertFactory\\)\n\n# 测试1: 短内容应该被惩罚，但惩罚更温和\nshort_content_output = {\n    ''task_execution_report'': {\n        ''deliverable_outputs'': [\n            {\n                ''deliverable_name'': ''测试交付物'',\n                ''content'': ''短内容'',  # 很短\n                ''quality_self_assessment'': 0.95\n            }\n        ]\n    }\n}\n\nresult = factory._calibrate_quality_scores\\(short_content_output, recorder=None\\)\ncalibrated_score = result[''task_execution_report''][''deliverable_outputs''][0][''quality_self_assessment'']\nprint\\(f''短内容校准: 0.95 -> {calibrated_score}''\\)\n\n# 新惩罚: 内容过短 0.10 + 缺少引用 0.05 + 缺少案例 0.03 + 缺少数据 0.02 = 0.20\n# 预期: 0.95 - 0.20 = 0.75\nassert calibrated_score >= 0.70, f''校准后分数 {calibrated_score} 应该 >= 0.70''\nassert calibrated_score <= 0.80, f''校准后分数 {calibrated_score} 应该 <= 0.80''\n\n# 测试2: 最低分应该是 0.6\nvery_low_output = {\n    ''task_execution_report'': {\n        ''deliverable_outputs'': [\n            {\n                ''deliverable_name'': ''测试交付物'',\n                ''content'': ''短'',\n                ''quality_self_assessment'': 0.65\n            }\n        ]\n    }\n}\n\nresult = factory._calibrate_quality_scores\\(very_low_output, recorder=None\\)\ncalibrated_score = result[''task_execution_report''][''deliverable_outputs''][0][''quality_self_assessment'']\nprint\\(f''低分校准: 0.65 -> {calibrated_score}''\\)\nassert calibrated_score >= 0.6, f''最低分应该是 0.6, 实际 {calibrated_score}''\n\n# 测试3: 优质内容惩罚应该较小\ngood_content = ''''''\n这是一个详细的分析报告，包含多个案例研究。\n\n案例1：拙政园的连廊设计\n根据研究数据显示，传统园林连廊的宽度通常在1.2-1.5米之间。\n统计表明，约80%的游客更喜欢有遮阳功能的连廊设计。\n\n案例2：留园的空间布局\n例如，留园的曲廊设计采用了\"移步换景\"的手法。\n调研发现，这种设计能够增加30%的空间感知深度。\n'''''' * 3\n\ngood_content_output = {\n    ''task_execution_report'': {\n        ''deliverable_outputs'': [\n            {\n                ''deliverable_name'': ''测试交付物'',\n                ''content'': good_content,\n                ''quality_self_assessment'': 0.95\n            }\n        ]\n    }\n}\n\nresult = factory._calibrate_quality_scores\\(good_content_output, recorder=None\\)\ncalibrated_score = result[''task_execution_report''][''deliverable_outputs''][0][''quality_self_assessment'']\nprint\\(f''优质内容校准: 0.95 -> {calibrated_score}''\\)\n# 优质内容只有搜索引用惩罚 0.05\nassert calibrated_score >= 0.85, f''优质内容不应被过度惩罚，实际评分: {calibrated_score}''\n\nprint\\(''✅ P2-2 测试通过!''\\)\n\")",
      "Bash(python -m pytest tests/test_minimal.py tests/test_v7154_fixes.py -v --tb=short)",
      "Bash(python check_checkpoint_data.py \"8pdwoxj8-20260108105020-0d341a8a\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\nimport json\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 1. 输出核心答案\n    print\\(''='' * 80\\)\n    print\\(''1. 核心答案 \\(core_answer\\)''\\)\n    print\\(''='' * 80\\)\n    final_report = cv.get\\(''final_report'', {}\\)\n    core_answer = final_report.get\\(''core_answer'', {}\\)\n    if core_answer:\n        print\\(f''问题: {core_answer.get\\(\"\"question\"\", \"\"N/A\"\"\\)[:200]}''\\)\n        print\\(f''答案: {core_answer.get\\(\"\"answer\"\", \"\"N/A\"\"\\)[:500]}''\\)\n        print\\(f''交付物: {core_answer.get\\(\"\"deliverables\"\", []\\)}''\\)\n        print\\(f''时间线: {core_answer.get\\(\"\"timeline\"\", \"\"N/A\"\"\\)}''\\)\n        print\\(f''预算: {core_answer.get\\(\"\"budget_range\"\", \"\"N/A\"\"\\)}''\\)\n    else:\n        print\\(''无核心答案''\\)\n    \n    # 2. 专家报告统计\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''2. 专家报告统计''\\)\n    print\\(''='' * 80\\)\n    expert_reports = final_report.get\\(''expert_reports'', {}\\)\n    print\\(f''专家报告数量: {len\\(expert_reports\\)}''\\)\n    for role_id, content in expert_reports.items\\(\\):\n        content_len = len\\(str\\(content\\)\\) if content else 0\n        print\\(f''  - {role_id}: {content_len} 字符''\\)\n    \n    # 3. 建议统计\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''3. 建议 \\(recommendations\\)''\\)\n    print\\(''='' * 80\\)\n    recommendations = final_report.get\\(''recommendations'', {}\\)\n    if recommendations:\n        rec_list = recommendations.get\\(''recommendations'', []\\)\n        print\\(f''建议数量: {len\\(rec_list\\)}''\\)\n        for i, rec in enumerate\\(rec_list[:5], 1\\):\n            print\\(f''  {i}. [{rec.get\\(\"\"dimension\"\", \"\"N/A\"\"\\)}] {rec.get\\(\"\"content\"\", \"\"N/A\"\"\\)[:100]}...''\\)\n    else:\n        print\\(''无建议''\\)\n    \n    # 4. 元数据\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''4. 报告元数据''\\)\n    print\\(''='' * 80\\)\n    metadata = final_report.get\\(''metadata'', {}\\)\n    print\\(f''生成时间: {metadata.get\\(\"\"generated_at\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''专家数量: {metadata.get\\(\"\"total_agents\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''整体置信度: {metadata.get\\(\"\"overall_confidence\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''预估页数: {metadata.get\\(\"\"estimated_pages\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''探询架构: {metadata.get\\(\"\"inquiry_architecture\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''复杂度: {metadata.get\\(\"\"complexity_level\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''分析耗时: {metadata.get\\(\"\"analysis_duration\"\", \"\"N/A\"\"\\)}''\\)\n    \n    # 5. 问卷数据\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''5. 问卷数据''\\)\n    print\\(''='' * 80\\)\n    questionnaire_responses = final_report.get\\(''questionnaire_responses''\\)\n    if questionnaire_responses:\n        responses = questionnaire_responses.get\\(''responses'', []\\)\n        print\\(f''问卷回答数: {len\\(responses\\)}''\\)\n    else:\n        print\\(''无问卷数据''\\)\n    \n    # 6. 审核反馈\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''6. 审核反馈''\\)\n    print\\(''='' * 80\\)\n    review_feedback = final_report.get\\(''review_feedback''\\)\n    if review_feedback:\n        print\\(f''红队质疑: {len\\(review_feedback.get\\(\"\"red_team_challenges\"\", []\\)\\)} 项''\\)\n        print\\(f''蓝队验证: {len\\(review_feedback.get\\(\"\"blue_team_validations\"\", []\\)\\)} 项''\\)\n        print\\(f''评委裁决: {len\\(review_feedback.get\\(\"\"judge_rulings\"\", []\\)\\)} 项''\\)\n    else:\n        print\\(''无审核反馈''\\)\n    \n    # 7. 洞察\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''7. 洞察 \\(insights\\)''\\)\n    print\\(''='' * 80\\)\n    insights = final_report.get\\(''insights'', {}\\)\n    if insights:\n        key_insights = insights.get\\(''key_insights'', []\\)\n        print\\(f''关键洞察数: {len\\(key_insights\\)}''\\)\n        for i, insight in enumerate\\(key_insights[:3], 1\\):\n            print\\(f''  {i}. {insight[:100]}...''\\)\n    else:\n        print\\(''无洞察数据''\\)\n    \n    # 8. 推敲过程\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''8. 推敲过程 \\(deliberation_process\\)''\\)\n    print\\(''='' * 80\\)\n    deliberation = final_report.get\\(''deliberation_process'', {}\\)\n    if deliberation:\n        print\\(f''探询架构: {deliberation.get\\(\"\"inquiry_architecture\"\", \"\"N/A\"\"\\)}''\\)\n        print\\(f''推理: {deliberation.get\\(\"\"reasoning\"\", \"\"N/A\"\"\\)[:200]}...''\\)\n        print\\(f''角色选择: {deliberation.get\\(\"\"role_selection\"\", []\\)}''\\)\n    else:\n        print\\(''无推敲过程''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\nimport json\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 检查 agent_results 的详细内容\n    print\\(''='' * 80\\)\n    print\\(''专家执行结果详情 \\(agent_results\\)''\\)\n    print\\(''='' * 80\\)\n    agent_results = cv.get\\(''agent_results'', {}\\)\n    \n    for role_id, result in agent_results.items\\(\\):\n        if role_id in [''RESULT_AGGREGATOR'', ''REPORT_GENERATOR'']:\n            continue\n        print\\(f''\\\\n--- {role_id} ---''\\)\n        if isinstance\\(result, dict\\):\n            print\\(f''  confidence: {result.get\\(\"\"confidence\"\", \"\"N/A\"\"\\)}''\\)\n            print\\(f''  expert_name: {result.get\\(\"\"expert_name\"\", \"\"N/A\"\"\\)}''\\)\n            \n            # 检查 structured_output\n            structured_output = result.get\\(''structured_output'', \\)\n            if structured_output:\n                print\\(f''  structured_output keys: {list\\(structured_output.keys\\(\\)\\)[:10]}''\\)\n                \n                # 检查 task_results\n                task_results = structured_output.get\\(''task_results'', []\\)\n                if task_results:\n                    print\\(f''  task_results count: {len\\(task_results\\)}''\\)\n                    for i, tr in enumerate\\(task_results[:2], 1\\):\n                        print\\(f''    {i}. deliverable_name: {tr.get\\(\"\"deliverable_name\"\", \"\"N/A\"\"\\)}''\\)\n                        print\\(f''       completeness_score: {tr.get\\(\"\"completeness_score\"\", \"\"N/A\"\"\\)}''\\)\n                        content = tr.get\\(''content'', ''''\\)\n                        print\\(f''       content length: {len\\(content\\)} chars''\\)\n            \n            # 检查 concept_images\n            concept_images = result.get\\(''concept_images'', []\\)\n            if concept_images:\n                print\\(f''  concept_images: {len\\(concept_images\\)} images''\\)\n            \n            # 检查 search_references\n            search_refs = result.get\\(''search_references'', []\\)\n            if search_refs:\n                print\\(f''  search_references: {len\\(search_refs\\)} refs''\\)\n        else:\n            print\\(f''  type: {type\\(result\\)}''\\)\n    \n    # 检查 strategic_analysis\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''战略分析 \\(strategic_analysis\\)''\\)\n    print\\(''='' * 80\\)\n    strategic = cv.get\\(''strategic_analysis'', {}\\)\n    if strategic:\n        print\\(f''query_type: {strategic.get\\(\"\"query_type\"\", \"\"N/A\"\"\\)}''\\)\n        print\\(f''query_type_reasoning: {strategic.get\\(\"\"query_type_reasoning\"\", \"\"N/A\"\"\\)[:200]}...''\\)\n        selected_roles = strategic.get\\(''selected_roles'', []\\)\n        print\\(f''selected_roles count: {len\\(selected_roles\\)}''\\)\n        for role in selected_roles[:5]:\n            if isinstance\\(role, dict\\):\n                print\\(f''  - {role.get\\(\"\"role_id\"\", \"\"N/A\"\"\\)}: {role.get\\(\"\"dynamic_role_name\"\", \"\"N/A\"\"\\)}''\\)\n    \n    # 检查 structured_requirements\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''结构化需求 \\(structured_requirements\\)''\\)\n    print\\(''='' * 80\\)\n    requirements = cv.get\\(''structured_requirements'', {}\\)\n    if requirements:\n        print\\(f''project_overview: {requirements.get\\(\"\"project_overview\"\", \"\"N/A\"\"\\)[:200]}...''\\)\n        print\\(f''core_objectives: {requirements.get\\(\"\"core_objectives\"\", []\\)}''\\)\n        print\\(f''design_focus: {requirements.get\\(\"\"design_focus\"\", []\\)}''\\)\n    \n    # 检查 deliverable_metadata\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''交付物元数据 \\(deliverable_metadata\\)''\\)\n    print\\(''='' * 80\\)\n    deliverable_meta = cv.get\\(''deliverable_metadata'', \\)\n    if deliverable_meta:\n        for d_id, d_meta in deliverable_meta.items\\(\\):\n            print\\(f''  {d_id}:''\\)\n            print\\(f''    name: {d_meta.get\\(\"\"name\"\", \"\"N/A\"\"\\)}''\\)\n            print\\(f''    owner: {d_meta.get\\(\"\"owner\"\", \"\"N/A\"\"\\)}''\\)\n            print\\(f''    supporters: {d_meta.get\\(\"\"supporters\"\", []\\)}''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\nimport json\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 检查 deliverable_metadata 和 deliverable_owner_map\n    print\\(''='' * 80\\)\n    print\\(''deliverable_metadata''\\)\n    print\\(''='' * 80\\)\n    dm = cv.get\\(''deliverable_metadata'', {}\\)\n    for d_id, meta in dm.items\\(\\):\n        print\\(f''{d_id}:''\\)\n        print\\(f''  name: {meta.get\\(\"\"name\"\", \"\"N/A\"\"\\)}''\\)\n        print\\(f''  owner: {meta.get\\(\"\"owner\"\", \"\"N/A\"\"\\)}''\\)\n        print\\(f''  supporters: {meta.get\\(\"\"supporters\"\", []\\)}''\\)\n    \n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''deliverable_owner_map''\\)\n    print\\(''='' * 80\\)\n    dom = cv.get\\(''deliverable_owner_map'', {}\\)\n    for d_id, owner in dom.items\\(\\):\n        print\\(f''{d_id}: {owner}''\\)\n    \n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''agent_results keys''\\)\n    print\\(''='' * 80\\)\n    ar = cv.get\\(''agent_results'', {}\\)\n    for key in ar.keys\\(\\):\n        print\\(f''  {key}''\\)\n    \n    # 检查一个专家的输出结构\n    print\\(\\)\n    print\\(''='' * 80\\)\n    print\\(''Sample agent_result structure \\(V2\\)''\\)\n    print\\(''='' * 80\\)\n    for key in ar.keys\\(\\):\n        if key.startswith\\(''V2_''\\):\n            result = ar[key]\n            print\\(f''Key: {key}''\\)\n            print\\(f''Keys in result: {list\\(result.keys\\(\\)\\) if isinstance\\(result, dict\\) else type\\(result\\)}''\\)\n            if isinstance\\(result, dict\\):\n                # 检查 structured_output\n                so = result.get\\(''structured_output''\\)\n                if so:\n                    print\\(f''structured_output keys: {list\\(so.keys\\(\\)\\) if isinstance\\(so, dict\\) else type\\(so\\)}''\\)\n                # 检查 structured_data\n                sd = result.get\\(''structured_data''\\)\n                if sd:\n                    print\\(f''structured_data keys: {list\\(sd.keys\\(\\)\\) if isinstance\\(sd, dict\\) else type\\(sd\\)}''\\)\n                    ter = sd.get\\(''task_execution_report''\\)\n                    if ter:\n                        print\\(f''task_execution_report keys: {list\\(ter.keys\\(\\)\\) if isinstance\\(ter, dict\\) else type\\(ter\\)}''\\)\n                        do = ter.get\\(''deliverable_outputs''\\)\n                        if do:\n                            print\\(f''deliverable_outputs count: {len\\(do\\)}''\\)\n                            if do:\n                                print\\(f''First deliverable_output keys: {list\\(do[0].keys\\(\\)\\) if isinstance\\(do[0], dict\\) else type\\(do[0]\\)}''\\)\n                                print\\(f''First deliverable_output name: {do[0].get\\(\"\"deliverable_name\"\", \"\"N/A\"\"\\)}''\\)\n                                content = do[0].get\\(''content'', ''''\\)\n                                print\\(f''First deliverable_output content length: {len\\(content\\)} chars''\\)\n                                print\\(f''First deliverable_output content preview: {content[:200]}...''\\)\n            break\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    dm = cv.get\\(''deliverable_metadata'', {}\\)\n    ar = cv.get\\(''agent_results'', {}\\)\n    \n    print\\(''Owner matching analysis:''\\)\n    print\\(''='' * 80\\)\n    \n    for d_id, meta in dm.items\\(\\):\n        owner = meta.get\\(''owner'', ''''\\)\n        print\\(f''\\\\nDeliverable: {d_id}''\\)\n        print\\(f''  Owner in metadata: {owner}''\\)\n        \n        # Check if owner exists in agent_results\n        if owner in ar:\n            print\\(f''  Direct match: YES''\\)\n        else:\n            print\\(f''  Direct match: NO''\\)\n            # Try prefix matching\n            parts = owner.split\\(''_''\\)\n            if len\\(parts\\) >= 2:\n                prefix = f''{parts[0]}_{parts[1]}''\n                print\\(f''  Prefix to match: {prefix}''\\)\n                for key in ar.keys\\(\\):\n                    if key.startswith\\(prefix\\):\n                        print\\(f''  Prefix match found: {key}''\\)\n                        break\n                else:\n                    print\\(f''  Prefix match: NOT FOUND''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"from intelligent_project_analyzer.report.result_aggregator import ResultAggregatorAgent, FinalReport; print\\(''Import successful''\\)\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\nimport json\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 检查问卷相关数据\n    print\\(''='' * 80\\)\n    print\\(''问卷相关数据''\\)\n    print\\(''='' * 80\\)\n    \n    # calibration_questionnaire\n    cq = cv.get\\(''calibration_questionnaire'', {}\\)\n    print\\(f''calibration_questionnaire: {\"\"有数据\"\" if cq else \"\"空\"\"}''\\)\n    if cq:\n        questions = cq.get\\(''questions'', []\\)\n        print\\(f''  questions count: {len\\(questions\\)}''\\)\n        for q in questions[:3]:\n            print\\(f''    - {q.get\\(\"\"question\"\", \"\"N/A\"\"\\)[:50]}...''\\)\n    \n    # questionnaire_responses\n    qr = cv.get\\(''questionnaire_responses'', {}\\)\n    print\\(f''questionnaire_responses: {\"\"有数据\"\" if qr else \"\"空\"\"}''\\)\n    if qr:\n        print\\(f''  keys: {list\\(qr.keys\\(\\)\\)}''\\)\n    \n    # calibration_answers\n    ca = cv.get\\(''calibration_answers'', {}\\)\n    print\\(f''calibration_answers: {\"\"有数据\"\" if ca else \"\"空\"\"}''\\)\n    if ca:\n        print\\(f''  keys: {list\\(ca.keys\\(\\)\\)[:5]}''\\)\n    \n    # structured_requirements\n    sr = cv.get\\(''structured_requirements'', {}\\)\n    print\\(f''\\\\nstructured_requirements:''\\)\n    print\\(f''  timeline: {sr.get\\(\"\"timeline\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''  budget_range: {sr.get\\(\"\"budget_range\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''  budget: {sr.get\\(\"\"budget\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''  project_timeline: {sr.get\\(\"\"project_timeline\"\", \"\"N/A\"\"\\)}''\\)\n    \n    # 检查 user_input\n    ui = cv.get\\(''user_input'', ''''\\)\n    print\\(f''\\\\nuser_input \\(前200字\\): {ui[:200]}...''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\nimport json\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 检查 structured_requirements 的所有字段\n    sr = cv.get\\(''structured_requirements'', {}\\)\n    print\\(''structured_requirements keys:''\\)\n    for key in sr.keys\\(\\):\n        value = sr[key]\n        if isinstance\\(value, str\\):\n            print\\(f''  {key}: {value[:100]}...'' if len\\(value\\) > 100 else f''  {key}: {value}''\\)\n        elif isinstance\\(value, list\\):\n            print\\(f''  {key}: [{len\\(value\\)} items]''\\)\n        elif isinstance\\(value, dict\\):\n            print\\(f''  {key}: {{...}}''\\)\n        else:\n            print\\(f''  {key}: {value}''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\nimport json\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 检查概念图数据\n    print\\(''='' * 80\\)\n    print\\(''概念图数据分析''\\)\n    print\\(''='' * 80\\)\n    \n    # generated_images_by_expert\n    gibe = cv.get\\(''generated_images_by_expert'', {}\\)\n    print\\(f''generated_images_by_expert: {len\\(gibe\\)} 个专家''\\)\n    for expert_id, data in gibe.items\\(\\):\n        images = data.get\\(''images'', []\\)\n        print\\(f''  {expert_id}: {len\\(images\\)} 张图''\\)\n        for img in images[:2]:\n            print\\(f''    - deliverable_id: {img.get\\(\"\"deliverable_id\"\", \"\"N/A\"\"\\)}''\\)\n            print\\(f''      image_url: {img.get\\(\"\"image_url\"\", img.get\\(\"\"url\"\", \"\"N/A\"\"\\)\\)[:50]}...''\\)\n    \n    # agent_results 中的 concept_images\n    print\\(\\)\n    print\\(''agent_results 中的 concept_images:''\\)\n    ar = cv.get\\(''agent_results'', {}\\)\n    for role_id, result in ar.items\\(\\):\n        if not isinstance\\(result, dict\\):\n            continue\n        concept_images = result.get\\(''concept_images'', []\\)\n        if concept_images:\n            print\\(f''  {role_id}: {len\\(concept_images\\)} 张图''\\)\n            for img in concept_images[:2]:\n                print\\(f''    - deliverable_id: {img.get\\(\"\"deliverable_id\"\", \"\"N/A\"\"\\)}''\\)\n                print\\(f''      url: {img.get\\(\"\"url\"\", \"\"N/A\"\"\\)[:50]}...''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 对比 deliverable_metadata 和 concept_images 的 deliverable_id\n    dm = cv.get\\(''deliverable_metadata'', {}\\)\n    ar = cv.get\\(''agent_results'', {}\\)\n    \n    print\\(''deliverable_metadata IDs:''\\)\n    for d_id in dm.keys\\(\\):\n        print\\(f''  {d_id}''\\)\n    \n    print\\(\\)\n    print\\(''concept_images deliverable_ids:''\\)\n    for role_id, result in ar.items\\(\\):\n        if not isinstance\\(result, dict\\):\n            continue\n        concept_images = result.get\\(''concept_images'', []\\)\n        for img in concept_images:\n            print\\(f''  {img.get\\(\"\"deliverable_id\"\", \"\"N/A\"\"\\)} \\(from {role_id}\\)''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport msgpack\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    dm = cv.get\\(''deliverable_metadata'', {}\\)\n    ar = cv.get\\(''agent_results'', {}\\)\n    \n    # 检查 D1 的情况\n    d1_meta = dm.get\\(''D1'', {}\\)\n    print\\(''D1 metadata:''\\)\n    print\\(f''  owner: {d1_meta.get\\(\"\"owner\"\", \"\"N/A\"\"\\)}''\\)\n    print\\(f''  name: {d1_meta.get\\(\"\"name\"\", \"\"N/A\"\"\\)}''\\)\n    \n    # 检查 V4 专家的概念图\n    for role_id, result in ar.items\\(\\):\n        if role_id.startswith\\(''V4_''\\):\n            print\\(f''\\\\n{role_id} concept_images:''\\)\n            concept_images = result.get\\(''concept_images'', []\\)\n            for img in concept_images:\n                print\\(f''  deliverable_id: {img.get\\(\"\"deliverable_id\"\", \"\"N/A\"\"\\)}''\\)\n    \n    # 检查 final_report 中的 concept_images\n    fr = cv.get\\(''final_report'', {}\\)\n    print\\(''\\\\nfinal_report.core_answer.deliverable_answers:''\\)\n    core_answer = fr.get\\(''core_answer'', {}\\)\n    da = core_answer.get\\(''deliverable_answers'', []\\)\n    for d in da[:3]:\n        print\\(f''  {d.get\\(\"\"deliverable_id\"\", \"\"N/A\"\"\\)}: concept_images={len\\(d.get\\(\"\"concept_images\"\", []\\)\\)}''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(python -c \"from intelligent_project_analyzer.report.result_aggregator import ResultAggregatorAgent; print\\(''Import successful''\\)\")",
      "Bash(python -c \"\n# 测试 1: 代码语法正确性\nprint\\(''='' * 80\\)\nprint\\(''测试 1: 代码语法正确性''\\)\nprint\\(''='' * 80\\)\n\ntry:\n    from intelligent_project_analyzer.report.result_aggregator import \\(\n        ResultAggregatorAgent, \n        FinalReport,\n        CoreAnswer,\n        DeliberationProcess,\n        RecommendationsSection\n    \\)\n    print\\(''✅ 所有模块导入成功''\\)\nexcept Exception as e:\n    print\\(f''❌ 导入失败: {e}''\\)\n    exit\\(1\\)\n\n# 检查 FinalReport 模型配置\nprint\\(f''\\\\nFinalReport.model_config.extra = {FinalReport.model_config.get\\(\"\"extra\"\", \"\"N/A\"\"\\)}''\\)\nprint\\(f''FinalReport 字段: {list\\(FinalReport.model_fields.keys\\(\\)\\)}''\\)\n\n# 检查 sections 字段是否存在\nif ''sections'' in FinalReport.model_fields:\n    print\\(''✅ sections 字段已添加''\\)\nelse:\n    print\\(''❌ sections 字段缺失''\\)\n\")",
      "Bash(python -c \"\n# 测试 3: timeline/budget 提取逻辑\nprint\\(''='' * 80\\)\nprint\\(''Test 3: timeline/budget extraction logic''\\)\nprint\\(''='' * 80\\)\n\ndef extract_timeline_budget\\(structured_requirements\\):\n    # timeline 提取\n    timeline = structured_requirements.get\\(''timeline''\\)\n    if not timeline or timeline == ''pending'':\n        constraints = structured_requirements.get\\(''constraints'', {}\\)\n        if isinstance\\(constraints, dict\\):\n            timeline = constraints.get\\(''timeline''\\) or constraints.get\\(''project_timeline''\\)\n    if not timeline or timeline in [''pending'', ''unclear'', ''N/A'', None]:\n        timeline = ''Please refer to expert report''\n    \n    # budget 提取\n    budget_range = structured_requirements.get\\(''budget_range''\\)\n    if not budget_range or budget_range == ''pending'':\n        constraints = structured_requirements.get\\(''constraints'', {}\\)\n        if isinstance\\(constraints, dict\\):\n            budget_range = constraints.get\\(''budget''\\) or constraints.get\\(''budget_range''\\)\n    if not budget_range or budget_range in [''pending'', ''unclear'', ''N/A'', None]:\n        budget_range = ''Please refer to expert report''\n    \n    return timeline, budget_range\n\n# 测试用例\ntest_cases = [\n    # Case 1: 顶层字段存在\n    {\n        ''input'': {''timeline'': ''3 months'', ''budget_range'': ''100k-200k''},\n        ''expected'': \\(''3 months'', ''100k-200k''\\)\n    },\n    # Case 2: 从 constraints 提取\n    {\n        ''input'': {''constraints'': {''timeline'': ''6 months'', ''budget'': ''500k''}},\n        ''expected'': \\(''6 months'', ''500k''\\)\n    },\n    # Case 3: 顶层为 pending，从 constraints 提取\n    {\n        ''input'': {''timeline'': ''pending'', ''constraints'': {''timeline'': ''1 year''}},\n        ''expected'': \\(''1 year'', ''Please refer to expert report''\\)\n    },\n    # Case 4: 全部为空，使用默认值\n    {\n        ''input'': {},\n        ''expected'': \\(''Please refer to expert report'', ''Please refer to expert report''\\)\n    },\n    # Case 5: 值为 unclear\n    {\n        ''input'': {''timeline'': ''unclear'', ''budget_range'': ''unclear''},\n        ''expected'': \\(''Please refer to expert report'', ''Please refer to expert report''\\)\n    },\n]\n\npassed = 0\nfailed = 0\nfor i, case in enumerate\\(test_cases, 1\\):\n    timeline, budget = extract_timeline_budget\\(case[''input'']\\)\n    expected_timeline, expected_budget = case[''expected'']\n    \n    if timeline == expected_timeline and budget == expected_budget:\n        print\\(f''[PASS] Case {i}: timeline={timeline}, budget={budget}''\\)\n        passed += 1\n    else:\n        print\\(f''[FAIL] Case {i}''\\)\n        print\\(f''       Expected: timeline={expected_timeline}, budget={expected_budget}''\\)\n        print\\(f''       Got: timeline={timeline}, budget={budget}''\\)\n        failed += 1\n\nprint\\(\\)\nprint\\(f''Results: {passed} passed, {failed} failed''\\)\n\")",
      "Bash(python -c \"\n# 测试 5: 概念图关联逻辑\nprint\\(''='' * 80\\)\nprint\\(''Test 5: Concept image association logic''\\)\nprint\\(''='' * 80\\)\n\ndef associate_concept_images\\(deliverable_id, concept_images_data\\):\n    ''''''模拟概念图关联逻辑''''''\n    concept_images = []\n    for img_data in concept_images_data:\n        img_deliverable_id = img_data.get\\(''deliverable_id'', ''''\\)\n        # 精确匹配\n        if img_deliverable_id == deliverable_id:\n            concept_images.append\\(img_data\\)\n        # 主交付物（如 D1）关联该专家的所有概念图\n        elif deliverable_id.startswith\\(''D''\\) and deliverable_id[1:].isdigit\\(\\):\n            concept_images.append\\(img_data\\)\n    return concept_images\n\n# 测试用例\nconcept_images_data = [\n    {''deliverable_id'': ''4-1_1_105654_elx'', ''url'': ''/images/img1.png''},\n    {''deliverable_id'': ''2-1_1_105654_ndb'', ''url'': ''/images/img2.png''},\n]\n\ntest_cases = [\n    # Case 1: 精确匹配\n    \\(''4-1_1_105654_elx'', 1\\),\n    # Case 2: 主交付物 D1 应该关联所有图片\n    \\(''D1'', 2\\),\n    # Case 3: 主交付物 D2 应该关联所有图片\n    \\(''D2'', 2\\),\n    # Case 4: 不匹配的交付物\n    \\(''3-1_1_105654_fls'', 0\\),\n    # Case 5: 非主交付物，不匹配\n    \\(''2-1_2_105654_emi'', 0\\),\n]\n\npassed = 0\nfailed = 0\nfor deliverable_id, expected_count in test_cases:\n    result = associate_concept_images\\(deliverable_id, concept_images_data\\)\n    actual_count = len\\(result\\)\n    \n    if actual_count == expected_count:\n        print\\(f''[PASS] {deliverable_id}: {actual_count} images''\\)\n        passed += 1\n    else:\n        print\\(f''[FAIL] {deliverable_id}: expected {expected_count}, got {actual_count}''\\)\n        failed += 1\n\nprint\\(\\)\nprint\\(f''Results: {passed} passed, {failed} failed''\\)\n\")",
      "Bash(python -c \"\n# 测试 6: fallback 报告生成 - 使用实际会话数据\nprint\\(''='' * 80\\)\nprint\\(''Test 6: Fallback report generation with real session data''\\)\nprint\\(''='' * 80\\)\n\nimport sqlite3\nimport msgpack\n\nsession_id = ''8pdwoxj8-20260108105020-0d341a8a''\nconn = sqlite3.connect\\(''data/checkpoints/workflow.db''\\)\ncursor = conn.cursor\\(\\)\n\ncursor.execute\\(''''''\n    SELECT checkpoint FROM checkpoints \n    WHERE thread_id = ? \n    ORDER BY checkpoint_id DESC LIMIT 1\n'''''', \\(session_id,\\)\\)\n\nrow = cursor.fetchone\\(\\)\nif row:\n    data = msgpack.unpackb\\(row[0], raw=False\\)\n    cv = data.get\\(''channel_values'', {}\\)\n    \n    # 模拟 extract_key_findings\n    agent_results = cv.get\\(''agent_results'', {}\\)\n    active_agents = cv.get\\(''active_agents'', []\\)\n    \n    findings = []\n    for role_id in active_agents:\n        if not any\\(role_id.startswith\\(prefix\\) for prefix in [''V2_'', ''V3_'', ''V4_'', ''V5_'', ''V6_'', ''V7_'']\\):\n            continue\n        agent_result = agent_results.get\\(role_id, {}\\)\n        if not isinstance\\(agent_result, dict\\):\n            continue\n        \n        # 从 analysis 字段提取\n        analysis = agent_result.get\\(''analysis'', ''''\\)\n        if analysis and len\\(analysis\\) > 50:\n            first_sentence = analysis.split\\(''.''\\)[0][:100]\n            if first_sentence and len\\(first_sentence\\) > 10:\n                findings.append\\(first_sentence\\)\n        \n        if len\\(findings\\) >= 3:\n            break\n    \n    print\\(''Extracted key findings:''\\)\n    for i, f in enumerate\\(findings, 1\\):\n        print\\(f''  {i}. {f[:80]}...''\\)\n    \n    # 检查是否有实际内容（非占位符）\n    has_real_content = any\\(\n        ''multi-agent'' not in f.lower\\(\\) and \n        ''placeholder'' not in f.lower\\(\\) and\n        len\\(f\\) > 20\n        for f in findings\n    \\)\n    \n    print\\(\\)\n    if findings and has_real_content:\n        print\\(''[PASS] Key findings extracted with real content''\\)\n    elif findings:\n        print\\(''[WARN] Key findings extracted but may be placeholder''\\)\n    else:\n        print\\(''[FAIL] No key findings extracted''\\)\n    \n    # 检查 strategic_analysis\n    strategic = cv.get\\(''strategic_analysis'', {}\\)\n    query_type = strategic.get\\(''query_type'', ''''\\)\n    query_reasoning = strategic.get\\(''query_type_reasoning'', ''''\\)\n    \n    print\\(\\)\n    print\\(''Strategic analysis:''\\)\n    print\\(f''  query_type: {query_type}''\\)\n    print\\(f''  reasoning: {query_reasoning[:100]}...'' if query_reasoning else ''  reasoning: \\(empty\\)''\\)\n    \n    if query_type and query_reasoning:\n        print\\(''[PASS] Strategic analysis has content''\\)\n    else:\n        print\\(''[WARN] Strategic analysis may be incomplete''\\)\n\nconn.close\\(\\)\n\")",
      "Bash(npx tsc --noEmit)",
      "Bash(python -m py_compile intelligent_project_analyzer/api/server.py)",
      "Bash(python -m py_compile intelligent_project_analyzer/services/file_processor.py)",
      "Bash(start http://localhost:3001)"
    ]
