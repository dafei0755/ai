      "Bash(python -c \"\nfrom intelligent_project_analyzer.services.core_task_decomposer import _simple_fallback_decompose\n\n# 测试1: 只传 user_input（旧的调用方式）\nresult1 = _simple_fallback_decompose\\(''设计一个智能家居系统''\\)\nprint\\(f''[TEST 1] 只传 user_input: 生成 {len\\(result1\\)} 个任务''\\)\nfor t in result1[:3]:\n    print\\(f''   - {t[\"\"title\"\"]}''\\)\n\n# 测试2: 传 user_input + structured_data（修复后的调用方式）\nstructured_data = {\n    ''design_challenge'': ''为年轻家庭设计智能家居控制系统'',\n    ''character_narrative'': ''35岁的科技爱好者，有两个孩子'',\n    ''project_type_label'': ''住宅设计''\n}\nresult2 = _simple_fallback_decompose\\(''设计一个智能家居系统'', structured_data\\)\nprint\\(f''[TEST 2] 传 user_input + structured_data: 生成 {len\\(result2\\)} 个任务''\\)\nfor t in result2[:3]:\n    print\\(f''   - {t[\"\"title\"\"]}''\\)\n\n# 验证修复是否生效\nprint\\(\\)\nif len\\(result2\\) >= len\\(result1\\):\n    print\\(''[PASS] structured_data 参数正常工作''\\)\nelse:\n    print\\(''[WARN] 结果数量异常''\\)\n\")",
      "Bash(python -c \"\n# 验证导入和参数传递\nfrom intelligent_project_analyzer.interaction.nodes.progressive_questionnaire import ProgressiveQuestionnaireNode\nfrom intelligent_project_analyzer.services.core_task_decomposer import _simple_fallback_decompose\nimport inspect\n\n# 检查 _simple_fallback_decompose 的签名\nsig = inspect.signature\\(_simple_fallback_decompose\\)\nprint\\(''[CHECK] _simple_fallback_decompose 参数:''\\)\nfor name, param in sig.parameters.items\\(\\):\n    default = param.default if param.default != inspect.Parameter.empty else ''必填''\n    print\\(f''   - {name}: {default}''\\)\n\n# 验证修复后的代码\nimport ast\nsource_file = ''d:/11-20/langgraph-design/intelligent_project_analyzer/interaction/nodes/progressive_questionnaire.py''\nwith open\\(source_file, ''r'', encoding=''utf-8''\\) as f:\n    content = f.read\\(\\)\n\n# 检查第119行和第124行\nlines = content.split\\(''\\\\n''\\)\nprint\\(\\)\nprint\\(''[CHECK] 修复后的代码:''\\)\nprint\\(f''   Line 119: {lines[118].strip\\(\\)}''\\)\nprint\\(f''   Line 124: {lines[123].strip\\(\\)}''\\)\n\n# 验证是否包含 structured_data\nif ''structured_data'' in lines[118] and ''structured_data'' in lines[123]:\n    print\\(\\)\n    print\\(''[PASS] 两处调用都已添加 structured_data 参数''\\)\nelse:\n    print\\(\\)\n    print\\(''[FAIL] 修复不完整''\\)\n\")",
