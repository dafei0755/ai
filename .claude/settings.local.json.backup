      "Bash(python -c \"\nimport sqlite3\nimport json\n\nconn = sqlite3.connect\\(''data/archived_sessions.db''\\)\ncursor = conn.cursor\\(\\)\n\n# 获取最近一个会话的图片信息\ncursor.execute\\(''SELECT session_id, final_report FROM archived_sessions ORDER BY created_at DESC LIMIT 1''\\)\nrow = cursor.fetchone\\(\\)\n\nif row:\n    session_id, final_report_json = row\n    final_report = json.loads\\(final_report_json\\)\n    imgs = final_report.get\\(''generated_images_by_expert'', {}\\)\n    \n    print\\(f''会话ID: {session_id}''\\)\n    print\\(f''专家数量: {len\\(imgs\\)}''\\)\n    print\\(\\)\n    \n    for expert_name, data in list\\(imgs.items\\(\\)\\)[:3]:\n        images = data.get\\(''images'', []\\) if isinstance\\(data, dict\\) else []\n        if images:\n            img = images[0]\n            print\\(f''专家: {expert_name}''\\)\n            print\\(f''  交付物ID: {img.get\\(\"\"deliverable_id\"\"\\)}''\\)\n            print\\(f''  Prompt: {img.get\\(\"\"prompt\"\", \"\"N/A\"\"\\)}''\\)\n            print\\(f''  文件名: {img.get\\(\"\"filename\"\", \"\"N/A\"\"\\)}''\\)\n            print\\(\\)\n\nconn.close\\(\\)\n\")",
