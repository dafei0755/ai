      "Bash(python -c \"\nfrom intelligent_project_analyzer.services.search_filter_manager import SearchFilterManager, get_filter_manager\n\n# 测试 1: 正常配置文件加载\nprint\\(''=== 测试 1: 正常配置文件加载 ===''\\)\nmanager = SearchFilterManager\\(register_global=False\\)\nconfig = manager.get_config\\(\\)\nprint\\(f''配置加载成功: blacklist={type\\(config.get\\(\"\"blacklist\"\"\\)\\)}, whitelist={type\\(config.get\\(\"\"whitelist\"\"\\)\\)}''\\)\n\nstats = manager.get_statistics\\(\\)\nprint\\(f''统计信息: 黑名单={stats[\"\"blacklist\"\"][\"\"total\"\"]}, 白名单={stats[\"\"whitelist\"\"][\"\"total\"\"]}''\\)\n\n# 测试 2: 模拟空配置（None 值）\nprint\\(''\\\\n=== 测试 2: 模拟空配置（None 值）===''\\)\nmanager2 = SearchFilterManager\\(register_global=False\\)\nmanager2._config = {''blacklist'': None, ''whitelist'': None, ''metadata'': None, ''scope'': None}\n\ntry:\n    config2 = manager2.get_config\\(\\)\n    print\\(f''get_config\\(\\) 成功: blacklist={type\\(config2.get\\(\"\"blacklist\"\"\\)\\)}, whitelist={type\\(config2.get\\(\"\"whitelist\"\"\\)\\)}''\\)\nexcept Exception as e:\n    print\\(f''get_config\\(\\) 失败: {e}''\\)\n\ntry:\n    stats2 = manager2.get_statistics\\(\\)\n    print\\(f''get_statistics\\(\\) 成功: 黑名单={stats2[\"\"blacklist\"\"][\"\"total\"\"]}, 白名单={stats2[\"\"whitelist\"\"][\"\"total\"\"]}''\\)\nexcept Exception as e:\n    print\\(f''get_statistics\\(\\) 失败: {e}''\\)\n\ntry:\n    blacklist = manager2.get_blacklist\\(\\)\n    whitelist = manager2.get_whitelist\\(\\)\n    print\\(f''get_blacklist/whitelist\\(\\) 成功: blacklist={type\\(blacklist\\)}, whitelist={type\\(whitelist\\)}''\\)\nexcept Exception as e:\n    print\\(f''get_blacklist/whitelist\\(\\) 失败: {e}''\\)\n\n# 测试 3: 全局单例\nprint\\(''\\\\n=== 测试 3: 全局单例 ===''\\)\nglobal_manager = get_filter_manager\\(\\)\nprint\\(f''全局管理器获取成功: {global_manager is not None}''\\)\nprint\\(f''统计信息: {global_manager.get_statistics\\(\\)}''\\)\n\nprint\\(''\\\\n✅ 所有测试通过!''\\)\n\")",
      "Bash(python -c \"\nfrom intelligent_project_analyzer.services.search_filter_manager import SearchFilterManager, get_filter_manager\n\n# 测试 1: 正常配置文件加载\nprint\\(''=== 测试 1: 正常配置文件加载 ===''\\)\nmanager = SearchFilterManager\\(register_global=False\\)\nconfig = manager.get_config\\(\\)\nprint\\(f''配置加载成功: blacklist={type\\(config.get\\(\"\"blacklist\"\"\\)\\)}, whitelist={type\\(config.get\\(\"\"whitelist\"\"\\)\\)}''\\)\n\nstats = manager.get_statistics\\(\\)\nprint\\(f''统计信息: 黑名单={stats[\"\"blacklist\"\"][\"\"total\"\"]}, 白名单={stats[\"\"whitelist\"\"][\"\"total\"\"]}''\\)\n\n# 测试 2: 模拟空配置（None 值）\nprint\\(''\\\\n=== 测试 2: 模拟空配置（None 值）===''\\)\nmanager2 = SearchFilterManager\\(register_global=False\\)\nmanager2._config = {''blacklist'': None, ''whitelist'': None, ''metadata'': None, ''scope'': None}\n\ntry:\n    config2 = manager2.get_config\\(\\)\n    print\\(f''get_config\\(\\) 成功: blacklist={type\\(config2.get\\(\"\"blacklist\"\"\\)\\)}, whitelist={type\\(config2.get\\(\"\"whitelist\"\"\\)\\)}''\\)\nexcept Exception as e:\n    print\\(f''get_config\\(\\) 失败: {e}''\\)\n\ntry:\n    stats2 = manager2.get_statistics\\(\\)\n    print\\(f''get_statistics\\(\\) 成功: 黑名单={stats2[\"\"blacklist\"\"][\"\"total\"\"]}, 白名单={stats2[\"\"whitelist\"\"][\"\"total\"\"]}''\\)\nexcept Exception as e:\n    print\\(f''get_statistics\\(\\) 失败: {e}''\\)\n\ntry:\n    blacklist = manager2.get_blacklist\\(\\)\n    whitelist = manager2.get_whitelist\\(\\)\n    print\\(f''get_blacklist/whitelist\\(\\) 成功: blacklist={type\\(blacklist\\)}, whitelist={type\\(whitelist\\)}''\\)\nexcept Exception as e:\n    print\\(f''get_blacklist/whitelist\\(\\) 失败: {e}''\\)\n\n# 测试 3: 黑白名单检查功能\nprint\\(''\\\\n=== 测试 3: 黑白名单检查功能 ===''\\)\nmanager3 = get_filter_manager\\(\\)\ntest_urls = [\n    ''https://archdaily.com/article/123'',\n    ''https://example-spam.com/page'',\n    ''https://unknown-site.com/test''\n]\nfor url in test_urls:\n    is_black = manager3.is_blacklisted\\(url\\)\n    is_white = manager3.is_whitelisted\\(url\\)\n    print\\(f''{url}: 黑名单={is_black}, 白名单={is_white}''\\)\n\nprint\\(''\\\\n✅ 所有测试通过!''\\)\n\")",
