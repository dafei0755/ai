      "Bash(python -c \"\nimport json\ndata = json.load\\(open\\(''temp_session_data.json'', encoding=''utf-8''\\)\\)\n\n# 检查结构化需求\nreq = data.get\\(''structured_requirements'', {}\\)\nprint\\(''=== Structured Requirements ===''\\)\nprint\\(''Style tags:'', req.get\\(''style_tags'', []\\)\\)\nprint\\(''Emotional needs:'', req.get\\(''emotional_needs'', []\\)\\)\nprint\\(''Spatial needs:'', req.get\\(''spatial_needs'', []\\)\\)\n\n# 检查agent_results\nresults = data.get\\(''agent_results'', {}\\)\nprint\\(''\\\\n=== Agent Results Structure ===''\\)\nif results:\n    for key in list\\(results.keys\\(\\)\\)[:5]:\n        print\\(f''{key}: {type\\(results[key]\\)}''\\)\nelse:\n    print\\(''No agent_results found''\\)\n\n# 检查events\nevents = data.get\\(''events'', []\\)\nprint\\(f''\\\\n=== Events \\({len\\(events\\)} total\\) ===''\\)\nfor i, evt in enumerate\\(events[:10]\\):\n    print\\(f''{i+1}. Type: {evt.get\\(\"\"type\"\"\\)}, Stage: {evt.get\\(\"\"stage\"\", \"\"N/A\"\"\\)}, Time: {evt.get\\(\"\"timestamp\"\", \"\"N/A\"\"\\)[:19]}''\\)\n\")",
