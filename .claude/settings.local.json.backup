      "Bash(python -c \"import sqlite3, json; conn = sqlite3.connect\\(''data/archived_sessions.db''\\); cursor = conn.cursor\\(\\); cursor.execute\\(''SELECT session_data FROM archived_sessions WHERE session_id = ?'', \\(''8pdwoxj8-20260106154858-dc82c8eb'',\\)\\); data = json.loads\\(cursor.fetchone\\(\\)[0]\\); report = data.get\\(''final_report'', ''''\\); print\\(''Final Report Length:'', len\\(report\\)\\); print\\(''First 500 chars:''\\); print\\(report[:500] if report else ''NO REPORT''\\); conn.close\\(\\)\")",
