      "Bash(python -c \"\nfrom intelligent_project_analyzer.settings import settings\nprint\\(''Serper Enabled:'', settings.serper.enabled\\)\nprint\\(''Serper API Key:'', settings.serper.api_key[:20] + ''...'' if settings.serper.api_key else ''None''\\)\nprint\\(''Is placeholder:'', settings.serper.api_key == ''your_serper_api_key_here''\\)\n\")",
      "Bash(python -c \"\nimport os\nfrom dotenv import load_dotenv\nload_dotenv\\(\\)\nprint\\(''SERPER_ENABLED from env:'', os.getenv\\(''SERPER_ENABLED''\\)\\)\nprint\\(''SERPER_API_KEY from env:'', os.getenv\\(''SERPER_API_KEY''\\)[:20] + ''...'' if os.getenv\\(''SERPER_API_KEY''\\) else ''None''\\)\n\")",
      "Bash(python -c \"\nimport os\nfrom dotenv import load_dotenv\nload_dotenv\\(\\)\n\nfrom intelligent_project_analyzer.core.types import ToolConfig\nfrom intelligent_project_analyzer.tools.serper_search import SerperSearchTool\n\n# 直接使用环境变量创建工具\napi_key = os.getenv\\(''SERPER_API_KEY''\\)\nprint\\(f''Using API key: {api_key[:20]}...''\\)\n\ntool = SerperSearchTool\\(api_key=api_key, config=ToolConfig\\(name=''serper_search''\\)\\)\n\n# 测试搜索\nprint\\(''\\\\n测试1: 简单搜索 \\(Python programming\\)''\\)\nresult = tool.search\\(query=''Python programming'', num_results=3\\)\nprint\\(f''Success: {result[\"\"success\"\"]}''\\)\nprint\\(f''Results count: {len\\(result.get\\(\"\"results\"\", []\\)\\)}''\\)\nif result.get\\(''results''\\):\n    print\\(f''First result: {result[\"\"results\"\"][0][\"\"title\"\"][:50]}...''\\)\n    print\\(f''URL: {result[\"\"results\"\"][0][\"\"url\"\"]}''\\)\n\")",
      "Bash(python -c \"\nimport os\nfrom dotenv import load_dotenv\nload_dotenv\\(\\)\n\nfrom intelligent_project_analyzer.core.types import ToolConfig\nfrom intelligent_project_analyzer.tools.serper_search import SerperSearchTool\n\napi_key = os.getenv\\(''SERPER_API_KEY''\\)\ntool = SerperSearchTool\\(api_key=api_key, config=ToolConfig\\(name=''serper_search''\\)\\)\n\n# 测试deliverable搜索\nprint\\(''测试2: Deliverable精准搜索''\\)\ndeliverable = {\n    ''name'': ''Market Research'',\n    ''description'': ''Comprehensive market analysis for retail design'',\n    ''format'': ''report''\n}\n\nresult = tool.search_for_deliverable\\(\n    deliverable=deliverable,\n    project_type=''retail'',\n    max_results=5\n\\)\n\nprint\\(f''Success: {result[\"\"success\"\"]}''\\)\nprint\\(f''Deliverable: {result.get\\(\"\"deliverable_name\"\"\\)}''\\)\nprint\\(f''Query: {result.get\\(\"\"precise_query\"\"\\)[:60]}...''\\)\nprint\\(f''Quality controlled: {result.get\\(\"\"quality_controlled\"\"\\)}''\\)\nprint\\(f''Results count: {len\\(result.get\\(\"\"results\"\", []\\)\\)}''\\)\nif result.get\\(''results''\\):\n    print\\(f''\\\\nTop result:''\\)\n    print\\(f''  Title: {result[\"\"results\"\"][0][\"\"title\"\"][:60]}...''\\)\n    print\\(f''  Reference #: {result[\"\"results\"\"][0].get\\(\"\"reference_number\"\"\\)}''\\)\n    print\\(f''  Score: {result[\"\"results\"\"][0].get\\(\"\"score\"\", 0\\):.2f}''\\)\n\")",
      "Bash(python -c \"\nimport os\nfrom dotenv import load_dotenv\nload_dotenv\\(\\)\n\nfrom intelligent_project_analyzer.core.types import ToolConfig\nfrom intelligent_project_analyzer.tools.serper_search import SerperSearchTool\n\napi_key = os.getenv\\(''SERPER_API_KEY''\\)\ntool = SerperSearchTool\\(api_key=api_key, config=ToolConfig\\(name=''serper_search''\\)\\)\n\n# 测试3: 中文搜索\nprint\\(''测试3: 中文搜索 \\(设计趋势 2024\\)''\\)\nresult = tool.search\\(\n    query=''设计趋势 2024'',\n    num_results=3,\n    gl=''cn'',\n    hl=''zh-cn''\n\\)\n\nprint\\(f''Success: {result[\"\"success\"\"]}''\\)\nprint\\(f''Results: {len\\(result.get\\(\"\"results\"\", []\\)\\)}''\\)\nprint\\(f''Execution time: {result.get\\(\"\"execution_time\"\", 0\\):.2f}s''\\)\nif result.get\\(''results''\\):\n    for i, r in enumerate\\(result[''results''][:2], 1\\):\n        print\\(f''{i}. {r[\"\"title\"\"][:40]}...''\\)\n\")",
      "Bash(python -c \"\nimport os\nfrom dotenv import load_dotenv\nload_dotenv\\(\\)\n\nprint\\(''='' * 60\\)\nprint\\(''✅ 博查 + Tavily 配置验证''\\)\nprint\\(''='' * 60\\)\n\n# 检查环境变量\nprint\\(''\\\\n📋 环境变量状态:''\\)\nprint\\(f''  Serper Enabled: {os.getenv\\(\"\"SERPER_ENABLED\"\"\\)}''\\)\nprint\\(f''  Bocha Enabled: {os.getenv\\(\"\"BOCHA_ENABLED\"\"\\)}''\\)\nprint\\(f''  Bocha API Key: {\"\"✓ 已配置\"\" if os.getenv\\(\"\"BOCHA_API_KEY\"\"\\) else \"\"✗ 未配置\"\"}''\\)\nprint\\(f''  Tavily API Key: {\"\"✓ 已配置\"\" if os.getenv\\(\"\"TAVILY_API_KEY\"\"\\) else \"\"✗ 未配置\"\"}''\\)\n\n# 检查工具工厂\nprint\\(''\\\\n🔧 工具工厂状态:''\\)\nfrom intelligent_project_analyzer.services.tool_factory import ToolFactory\n\ntools = ToolFactory.create_all_tools\\(\\)\nprint\\(f''  可用工具数量: {len\\(tools\\)}''\\)\nfor name, tool in tools.items\\(\\):\n    print\\(f''    - {name}: {getattr\\(tool, \"\"name\"\", \"\"unknown\"\"\\)}''\\)\n\nprint\\(''\\\\n✅ 配置验证完成''\\)\nprint\\(''='' * 60\\)\n\")",
      "Bash(python -c \"\nimport os\nfrom dotenv import load_dotenv\nload_dotenv\\(\\)\n\nprint\\(''='' * 60\\)\nprint\\(''Bocha + Tavily Configuration Verification''\\)\nprint\\(''='' * 60\\)\n\n# Check environment variables\nprint\\(''\\\\nEnvironment Variables:''\\)\nprint\\(f''  Serper Enabled: {os.getenv\\(\"\"SERPER_ENABLED\"\"\\)}''\\)\nprint\\(f''  Bocha Enabled: {os.getenv\\(\"\"BOCHA_ENABLED\"\"\\)}''\\)\nprint\\(f''  Bocha API Key: {\"\"OK\"\" if os.getenv\\(\"\"BOCHA_API_KEY\"\"\\) else \"\"NOT SET\"\"}''\\)\nprint\\(f''  Tavily API Key: {\"\"OK\"\" if os.getenv\\(\"\"TAVILY_API_KEY\"\"\\) else \"\"NOT SET\"\"}''\\)\n\n# Check ToolFactory\nprint\\(''\\\\nToolFactory Status:''\\)\nfrom intelligent_project_analyzer.services.tool_factory import ToolFactory\n\ntools = ToolFactory.create_all_tools\\(\\)\nprint\\(f''  Available tools: {len\\(tools\\)}''\\)\nfor name, tool in tools.items\\(\\):\n    print\\(f''    - {name}: {getattr\\(tool, \"\"name\"\", \"\"unknown\"\"\\)}''\\)\n\nprint\\(''\\\\nConfiguration verified successfully''\\)\nprint\\(''='' * 60\\)\n\")",
      "Bash(python -c \"\nprint\\(''Tool Description Verification''\\)\nprint\\(''='' * 60\\)\n\nfrom intelligent_project_analyzer.services.tool_factory import ToolFactory\n\ntools = ToolFactory.create_all_tools\\(\\)\n\nprint\\(''\\\\nBocha Description:''\\)\nif ''bocha'' in tools:\n    bocha_desc = tools[''bocha''].description\n    print\\(bocha_desc[:200] + ''...''\\)\n    \nprint\\(''\\\\nTavily Description:''\\)\nif ''tavily'' in tools:\n    tavily_desc = tools[''tavily''].description\n    print\\(tavily_desc[:200] + ''...''\\)\n\")",
      "Bash(python -c \"\nfrom intelligent_project_analyzer.settings import settings\n\nprint\\(''='' * 60\\)\nprint\\(''🔍 搜索工具最终配置状态验证''\\)\nprint\\(''='' * 60\\)\n\n# 检查搜索工具状态\nprint\\(''\\\\n📊 搜索工具启用状态:''\\)\nprint\\(f''  Serper: {settings.serper.enabled}''\\)\nprint\\(f''  Bocha: {settings.bocha.enabled}''\\)\nprint\\(f''  Tavily: {bool\\(settings.tavily.api_key\\)}''\\)\nprint\\(f''  ArXiv: {settings.arxiv.enabled}''\\)\n\n# 检查工具配置\nprint\\(''\\\\n🔧 工具配置详情:''\\)\nprint\\(f''  Tavily API Key: {''已配置'' if settings.tavily.api_key else ''未配置''}''\\)\nprint\\(f''  Bocha API Key: {''已配置'' if settings.bocha.api_key and settings.bocha.api_key != ''your_bocha_api_key_here'' else ''未配置''}''\\)\nprint\\(f''  Serper API Key: {''已配置'' if settings.serper.api_key else ''未配置''}''\\)\n\nprint\\(''\\\\n✅ 配置验证完成''\\)\nprint\\(''='' * 60\\)\n\")",
      "Bash(python -c \"\nfrom intelligent_project_analyzer.services.tool_factory import ToolFactory\nfrom intelligent_project_analyzer.settings import settings\n\nprint\\(''='' * 60\\)\nprint\\(''Language Barrier-Free Search System - Final Configuration''\\)\nprint\\(''='' * 60\\)\n\nprint\\(''\\\\n1. Search Tool Status:''\\)\nprint\\(f''   Serper \\(Google\\): {settings.serper.enabled} \\(Disabled - SSL issues in China\\)''\\)\nprint\\(f''   Tavily \\(Global\\): Enabled \\(PRIMARY - Multi-language global coverage\\)''\\)\nprint\\(f''   Bocha \\(Chinese\\): {settings.bocha.enabled} \\(SECONDARY - Domestic content only\\)''\\)\nprint\\(f''   ArXiv \\(Academic\\): {settings.arxiv.enabled}''\\)\n\nprint\\(''\\\\n2. Tool Priority Strategy:''\\)\nprint\\(''   Global Queries \\(Chinese/English\\): Tavily >> Bocha >> Serper''\\)\nprint\\(''   Academic Papers: ArXiv''\\)\nprint\\(''   Internal KB: RAGFlow''\\)\n\nprint\\(''\\\\n3. Language Barrier Breaking:''\\)\nprint\\(''   Chinese Query -> Tavily \\(auto-matches global English sites\\)''\\)\nprint\\(''   English Query -> Tavily \\(direct global search\\)''\\)\nprint\\(''   No explicit translation needed''\\)\n\nprint\\(''\\\\n4. Available Tools:''\\)\ntools = ToolFactory.create_all_tools\\(\\)\nfor name, tool in tools.items\\(\\):\n    tool_name = getattr\\(tool, ''name'', ''unknown''\\)\n    print\\(f''   - {name}: {tool_name}''\\)\n\nprint\\(''\\\\n5. Role-Tool Mapping \\(main_workflow.py\\):''\\)\nprint\\(''   V2: ragflow''\\)\nprint\\(''   V3: bocha, tavily, ragflow''\\)\nprint\\(''   V4: bocha, tavily, arxiv, ragflow''\\)\nprint\\(''   V5: bocha, tavily, ragflow''\\)\nprint\\(''   V6: bocha, tavily, arxiv, ragflow''\\)\n\nprint\\(''\\\\nConfiguration verified successfully''\\)\nprint\\(''='' * 60\\)\n\")",
