      "Bash(curl -s \"http://localhost:3000/generated_images/8pdwoxj8-20260103162422-3a46bd9b/2-1_2_162659_lkr_personal_residential_20260103_163442.png\" -I)",
      "Bash(python -c \"\nimport sqlite3\nconn = sqlite3.connect\\(''data/archived_sessions.db''\\)\ncursor = conn.cursor\\(\\)\ncursor.execute\\(''SELECT final_report FROM sessions WHERE session_id = ?'', \\(''8pdwoxj8-20260103162422-3a46bd9b'',\\)\\)\nrow = cursor.fetchone\\(\\)\nif row:\n    import json\n    final_report = json.loads\\(row[0]\\)\n    imgs = final_report.get\\(''generated_images_by_expert'', {}\\)\n    print\\(f''Total experts with images: {len\\(imgs\\)}''\\)\n    for expert, data in list\\(imgs.items\\(\\)\\)[:2]:\n        print\\(f''{expert}: {len\\(data.get\\(\"\"images\"\", []\\)\\)} images''\\)\n        if data.get\\(''images''\\):\n            print\\(f''  First image URL: {data[\"\"images\"\"][0].get\\(\"\"image_url\"\"\\) or data[\"\"images\"\"][0].get\\(\"\"url\"\"\\)}''\\)\nelse:\n    print\\(''Session not found in archived_sessions''\\)\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nconn = sqlite3.connect\\(''data/archived_sessions.db''\\)\ncursor = conn.cursor\\(\\)\ncursor.execute\\(''SELECT name FROM sqlite_master WHERE type=\"\"table\"\"''\\)\nprint\\(''Tables:'', [row[0] for row in cursor.fetchall\\(\\)]\\)\nconn.close\\(\\)\n\")",
      "Bash(python -c \"\nimport sqlite3\nimport json\nconn = sqlite3.connect\\(''data/archived_sessions.db''\\)\ncursor = conn.cursor\\(\\)\ncursor.execute\\(''SELECT final_report FROM archived_sessions WHERE session_id = ?'', \\(''8pdwoxj8-20260103162422-3a46bd9b'',\\)\\)\nrow = cursor.fetchone\\(\\)\nif row and row[0]:\n    final_report = json.loads\\(row[0]\\)\n    imgs = final_report.get\\(''generated_images_by_expert'', {}\\)\n    print\\(f''Total experts with images: {len\\(imgs\\)}''\\)\n    for expert, data in list\\(imgs.items\\(\\)\\)[:3]:\n        images = data.get\\(''images'', []\\) if isinstance\\(data, dict\\) else []\n        print\\(f''{expert}: {len\\(images\\)} images''\\)\n        if images:\n            img = images[0]\n            print\\(f''  URL: {img.get\\(\"\"image_url\"\"\\) or img.get\\(\"\"url\"\"\\)}''\\)\n            print\\(f''  ID: {img.get\\(\"\"id\"\"\\)}''\\)\nelse:\n    print\\(''Session not found or no final_report''\\)\nconn.close\\(\\)\n\")",
      "Bash(python scripts/test_api_response.py)",
      "Bash(python -c \"\nimport sys, json\ndata = json.load\\(sys.stdin\\)\nsr = data.get\\(''structured_report'', {}\\)\nimgs_by_expert = sr.get\\(''generated_images_by_expert''\\)\nprint\\(''Type:'', type\\(imgs_by_expert\\)\\)\nprint\\(''Value:'', imgs_by_expert\\)\nif imgs_by_expert:\n    print\\(''\\\\nExperts:'', list\\(imgs_by_expert.keys\\(\\)\\)\\)\n    for k, v in list\\(imgs_by_expert.items\\(\\)\\)[:2]:\n        print\\(f''\\\\n{k}:''\\)\n        print\\(''  Type:'', type\\(v\\)\\)\n        print\\(''  Keys:'', list\\(v.keys\\(\\)\\) if isinstance\\(v, dict\\) else ''N/A''\\)\n        if isinstance\\(v, dict\\):\n            imgs = v.get\\(''images'', []\\)\n            print\\(''  Images count:'', len\\(imgs\\)\\)\n            if imgs:\n                print\\(''  First image:'', imgs[0]\\)\n\")",
      "Bash(python -c \"\nimport redis\nimport json\nimport asyncio\n\nasync def check_redis\\(\\):\n    r = redis.asyncio.from_url\\(''redis://localhost:6379/0''\\)\n    try:\n        session_json = await r.get\\(''session:8pdwoxj8-20260103162422-3a46bd9b''\\)\n        if not session_json:\n            print\\(''Session not found in Redis''\\)\n            return\n        \n        session = json.loads\\(session_json\\)\n        final_report = session.get\\(''final_report'', {}\\)\n        imgs = final_report.get\\(''generated_images_by_expert''\\)\n        \n        print\\(f''final_report keys: {list\\(final_report.keys\\(\\)\\)[:10]}''\\)\n        print\\(f''\\\\ngenerated_images_by_expert type: {type\\(imgs\\)}''\\)\n        print\\(f''generated_images_by_expert value: {imgs is not None}''\\)\n        \n        if imgs:\n            print\\(f''\\\\nExperts: {list\\(imgs.keys\\(\\)\\)[:3]}''\\)\n    finally:\n        await r.close\\(\\)\n\nasyncio.run\\(check_redis\\(\\)\\)\n\")",
      "Bash(python -c \"\nimport redis\nimport json\nimport asyncio\n\nasync def test_normalize\\(\\):\n    from intelligent_project_analyzer.api.server import _normalize_image_urls\n    \n    r = redis.asyncio.from_url\\(''redis://localhost:6379/0''\\)\n    try:\n        session_json = await r.get\\(''session:8pdwoxj8-20260103162422-3a46bd9b''\\)\n        session = json.loads\\(session_json\\)\n        final_report = session.get\\(''final_report'', {}\\)\n        imgs_raw = final_report.get\\(''generated_images_by_expert''\\)\n        \n        print\\(f''Raw data type: {type\\(imgs_raw\\)}''\\)\n        print\\(f''Raw data is dict: {isinstance\\(imgs_raw, dict\\)}''\\)\n        print\\(f''Raw data keys: {list\\(imgs_raw.keys\\(\\)\\)[:3] if isinstance\\(imgs_raw, dict\\) else \"\"N/A\"\"}''\\)\n        \n        # 测试normalize函数\n        normalized = _normalize_image_urls\\(imgs_raw\\)\n        \n        print\\(f''\\\\nNormalized type: {type\\(normalized\\)}''\\)\n        print\\(f''Normalized is None: {normalized is None}''\\)\n        if normalized:\n            print\\(f''Normalized keys: {list\\(normalized.keys\\(\\)\\)[:3]}''\\)\n            first_expert = list\\(normalized.keys\\(\\)\\)[0]\n            print\\(f''\\\\nFirst expert \\({first_expert}\\):''\\)\n            print\\(f''  Type: {type\\(normalized[first_expert]\\)}''\\)\n            if isinstance\\(normalized[first_expert], dict\\):\n                print\\(f''  Keys: {list\\(normalized[first_expert].keys\\(\\)\\)}''\\)\n                imgs = normalized[first_expert].get\\(''images'', []\\)\n                print\\(f''  Images: {len\\(imgs\\)}''\\)\n                if imgs:\n                    print\\(f''  First image keys: {list\\(imgs[0].keys\\(\\)\\)}''\\)\n                    print\\(f''  First image_url: {imgs[0].get\\(\"\"image_url\"\"\\)}''\\)\n    finally:\n        await r.close\\(\\)\n\nasyncio.run\\(test_normalize\\(\\)\\)\n\")",
      "Bash(python -c \"\n# 直接测试API endpoint的逻辑\nimport asyncio\nimport sys\nsys.path.insert\\(0, ''D:\\\\\\\\11-20\\\\\\\\langgraph-design''\\)\n\nfrom intelligent_project_analyzer.api.server import get_analysis_report\n\nasync def test\\(\\):\n    try:\n        result = await get_analysis_report\\(''8pdwoxj8-20260103162422-3a46bd9b''\\)\n        print\\(''Result type:'', type\\(result\\)\\)\n        print\\(''\\\\nResult dict:'', result.dict\\(\\) if hasattr\\(result, ''dict''\\) else result\\)\n        \n        if hasattr\\(result, ''structured_report''\\) and result.structured_report:\n            sr = result.structured_report\n            print\\(''\\\\nStructured report keys:'', sr.dict\\(\\).keys\\(\\) if hasattr\\(sr, ''dict''\\) else dir\\(sr\\)\\)\n            if hasattr\\(sr, ''generated_images_by_expert''\\):\n                print\\(''\\\\ngenerated_images_by_expert:'', sr.generated_images_by_expert\\)\n    except Exception as e:\n        print\\(f''Error: {e}''\\)\n        import traceback\n        traceback.print_exc\\(\\)\n\nasyncio.run\\(test\\(\\)\\)\n\")",
