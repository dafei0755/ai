      "Bash(python -c \"import os; print\\(''ENABLE_DIMENSION_LEARNING:'', os.getenv\\(''ENABLE_DIMENSION_LEARNING'', ''not set''\\)\\); print\\(''USE_DYNAMIC_GENERATION:'', os.getenv\\(''USE_DYNAMIC_GENERATION'', ''not set''\\)\\); print\\(''FORCE_GENERATE_DIMENSIONS:'', os.getenv\\(''FORCE_GENERATE_DIMENSIONS'', ''not set''\\)\\)\")",
      "Bash(python -c \"from dotenv import load_dotenv; from pathlib import Path; env_path = Path\\(''.env''\\); load_dotenv\\(env_path\\); import os; print\\(''USE_DYNAMIC_GENERATION:'', os.getenv\\(''USE_DYNAMIC_GENERATION''\\)\\); print\\(''FORCE_GENERATE_DIMENSIONS:'', os.getenv\\(''FORCE_GENERATE_DIMENSIONS''\\)\\); print\\(''ENABLE_DIMENSION_LEARNING:'', os.getenv\\(''ENABLE_DIMENSION_LEARNING''\\)\\)\")",
      "Bash(if [ -f .env ])",
      "Bash(then echo \"=== .env 文件存在，显示内容 ===\")",
      "Bash(cat .env)",
      "Bash(else echo \"=== .env 文件不存在 ===\")",
      "Bash(python -c \"\nimport os\nos.environ[''USE_DYNAMIC_GENERATION''] = ''true''\n\nfrom intelligent_project_analyzer.services.dynamic_dimension_generator import DynamicDimensionGenerator\n\n# 测试动态维度生成器初始化\ngenerator = DynamicDimensionGenerator\\(\\)\nprint\\(''✅ DynamicDimensionGenerator 初始化成功''\\)\n\n# 模拟现有维度\nexisting_dimensions = [\n    {\n        ''id'': ''material_temperature'',\n        ''name'': ''材质温度轴'',\n        ''left_label'': ''冷峻硬朗'',\n        ''right_label'': ''温润柔和'',\n        ''description'': ''从冷峻硬朗到温润柔和的材质倾向'',\n        ''category'': ''aesthetic'',\n        ''default_value'': 50,\n    }\n]\n\n# 测试覆盖度分析\nuser_input = ''设计一个南极科考站的居住空间，需要考虑极端环境适应性''\nstructured_data = {''project_type'': ''commercial_space''}\n\nprint\\(''\\\\n🔍 测试覆盖度分析...''\\)\nprint\\(f''用户输入: {user_input}''\\)\nprint\\(f''现有维度数量: {len\\(existing_dimensions\\)}''\\)\n\ntry:\n    coverage = generator.analyze_coverage\\(user_input, structured_data, existing_dimensions\\)\n    print\\(f''\\\\n✅ 覆盖度分析完成:''\\)\n    print\\(f''  - 覆盖评分: {coverage.get\\(\"\"coverage_score\"\", 0\\):.2f}''\\)\n    print\\(f''  - 是否需要生成: {coverage.get\\(\"\"should_generate\"\", False\\)}''\\)\n    print\\(f''  - 缺失方面: {coverage.get\\(\"\"missing_aspects\"\", []\\)}''\\)\n    \n    if coverage.get\\(''should_generate'', False\\):\n        print\\(''\\\\n🤖 测试维度生成...''\\)\n        new_dimensions = generator.generate_dimensions\\(\n            user_input,\n            {**structured_data, ''existing_dimensions'': existing_dimensions},\n            coverage.get\\(''missing_aspects'', []\\),\n            target_count=2\n        \\)\n        print\\(f''\\\\n✅ 成功生成 {len\\(new_dimensions\\)} 个新维度:''\\)\n        for dim in new_dimensions:\n            print\\(f''  - {dim[\"\"name\"\"]}: {dim[\"\"left_label\"\"]} ↔ {dim[\"\"right_label\"\"]}''\\)\n    else:\n        print\\(''\\\\n✅ 现有维度覆盖充分，无需生成新维度''\\)\n        \nexcept Exception as e:\n    print\\(f''\\\\n❌ 测试失败: {e}''\\)\n    import traceback\n    traceback.print_exc\\(\\)\n\")",
