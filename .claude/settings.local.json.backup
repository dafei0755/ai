      "Bash(python -c \"\nfrom tavily_search import TavilySearchTool\nfrom arxiv_search import ArxivSearchTool\nfrom ragflow_kb import RagflowKBTool\nfrom intelligent_project_analyzer.core.types import ToolConfig\n\n# Check each tool\ntools = []\n\n# Tavily\ntry:\n    t = TavilySearchTool\\(api_key=''test''\\)\n    has_name = hasattr\\(t, ''name''\\)\n    has_config = hasattr\\(t, ''config''\\)\n    config_name = t.config.name if has_config else ''N/A''\n    tools.append\\(f''TavilySearchTool: name={has_name}, config={has_config}, config.name={config_name}''\\)\nexcept Exception as e:\n    tools.append\\(f''TavilySearchTool: ERROR - {e}''\\)\n\n# Arxiv  \ntry:\n    a = ArxivSearchTool\\(\\)\n    has_name = hasattr\\(a, ''name''\\)\n    has_config = hasattr\\(a, ''config''\\)\n    config_name = a.config.name if has_config else ''N/A''\n    tools.append\\(f''ArxivSearchTool: name={has_name}, config={has_config}, config.name={config_name}''\\)\nexcept Exception as e:\n    tools.append\\(f''ArxivSearchTool: ERROR - {e}''\\)\n\n# Ragflow\ntry:\n    r = RagflowKBTool\\(api_endpoint=''test'', api_key=''test'', dataset_id=''test''\\)\n    has_name = hasattr\\(r, ''name''\\)\n    has_config = hasattr\\(r, ''config''\\)\n    config_name = r.config.name if has_config else ''N/A''\n    tools.append\\(f''RagflowKBTool: name={has_name}, config={has_config}, config.name={config_name}''\\)\nexcept Exception as e:\n    tools.append\\(f''RagflowKBTool: ERROR - {e}''\\)\n\nfor t in tools:\n    print\\(t\\)\n\")",
