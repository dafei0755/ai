# 环境配置示例 - 开发环境
# 复制此文件为 .env.development 并根据需要修改

# ========================================
# 环境配置
# ========================================
ENVIRONMENT=development

# ========================================
# 日志配置
# ========================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# development默认: DEBUG
# staging默认: DEBUG
# production默认: INFO
LOG_LEVEL=DEBUG

# 结构化日志（JSON格式）
# true: JSON格式，便于机器解析
# false: 人类可读格式（推荐开发环境）
STRUCTURED_LOGGING=false

# 详细日志（包含DEBUG payload等）
ENABLE_DETAILED_LOGGING=true

# 日志采样率（0.0-1.0）
# 1.0 = 100%记录，0.1 = 10%采样
LOG_SAMPLE_RATE=1.0

# ========================================
# 监控配置
# ========================================

# 启用监控
ENABLE_MONITORING=true

# 慢查询阈值（秒）
# 超过此时间的操作将被记录为慢查询
SLOW_QUERY_THRESHOLD=2.0

# ========================================
# 其他配置
# ========================================

# Redis配置（如果使用）
# REDIS_HOST=localhost
# REDIS_PORT=6379

# API配置
# TAVILY_API_KEY=your_key_here

# Serper搜索配置 (v7.130+, 中国网络环境可能不稳定)
# 获取密钥: https://serper.dev/
# 免费额度: 2500次/月
# ⚠️ 注意：在中国可能出现SSL连接问题，建议优先使用博查+Tavily
# SERPER_ENABLED=false
# SERPER_API_KEY=your_serper_api_key_here

# BOCHA_API_KEY=your_key_here

# ========================================
# Milvus 向量数据库知识库配置 (v7.141+)
# ========================================

# 启用 Milvus 知识库 (优先使用，性能更优)
MILVUS_ENABLED=true

# Milvus 服务器配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Collection 配置
MILVUS_COLLECTION_NAME=design_knowledge_base

# Embedding 模型配置
# 推荐: BAAI/bge-m3 (中英文支持，1024维)
MILVUS_EMBEDDING_MODEL=BAAI/bge-m3
MILVUS_EMBEDDING_DIM=1024

# 检索配置
MILVUS_SIMILARITY_THRESHOLD=0.6  # 粗排相似度阈值
MILVUS_CANDIDATE_MULTIPLIER=5    # 候选集扩大倍数

# Reranker 配置 (重排序优化)
MILVUS_RERANK_ENABLED=true
MILVUS_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
MILVUS_RERANK_WEIGHT=0.7  # 重排序分数权重 (0.7表示70%重排+30%向量)

# 去重配置
MILVUS_DEDUP_THRESHOLD=0.95  # 文档去重相似度阈值

# 性能配置
MILVUS_TIMEOUT=30
MILVUS_BATCH_SIZE=32

# ========================================
# LLM维度推荐器配置 (v7.138+)
# ========================================

# 启用LLM维度推荐器
# true: 启用LLM推荐（需要LLM服务可用）
# false: 禁用LLM推荐，仅使用规则引擎（默认，保守策略）
# 功能：使用LLM深度理解用户需求，推荐雷达图维度，提升准确率从85%到95%
ENABLE_LLM_DIMENSION_RECOMMENDER=false

# ========================================
# 雷达图维度智能选择配置 (v7.147+)
# ========================================

# 启用智能维度学习（推荐开启）
# true: 使用 AdaptiveDimensionGenerator，基于历史数据学习优化维度选择
# false: 使用传统 RuleEngine，从 YAML 配置文件加载静态维度
# 性能影响：最小（历史数据在后台线程加载，10秒超时）
# 功能：
#   - 从 Redis 加载历史维度使用数据
#   - 自动检测特殊场景（极端环境、医疗需求、文化深度等）
#   - 学习用户偏好模式，持续优化维度选择
#   - 提升维度相关性和用户满意度
# 依赖：需要 Redis 运行（如果 Redis 不可用，自动降级到 RuleEngine）
ENABLE_DIMENSION_LEARNING=true

# 启用LLM动态维度生成（谨慎开启）
# true: 使用 DynamicDimensionGenerator，LLM 实时分析用户输入生成自定义维度
# false: 不使用 LLM 动态生成（推荐，避免延迟）
# 性能影响：高（每次问卷增加 2-5 秒 LLM 调用延迟）
# 功能：
#   - LLM 深度分析用户需求
#   - 为独特/复杂项目生成定制维度
#   - 覆盖维度库中不存在的场景
# 建议：仅在 ENABLE_DIMENSION_LEARNING 无法满足需求时启用
USE_DYNAMIC_GENERATION=false

# 强制维度生成模式（仅用于测试/演示）
# true: 强制使用动态生成，忽略其他配置
# false: 正常模式（推荐）
# 用途：测试动态生成功能，演示智能维度能力
FORCE_GENERATE_DIMENSIONS=false
