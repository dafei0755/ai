# ============================================
# Intelligent Project Analyzer - 环境变量配置
# ============================================

# ============================================
# 1. LLM 服务配置（必填其一）
# ============================================

# OpenAI API 配置（推荐）
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic Claude API（可选）
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google Gemini API（可选）
# GOOGLE_API_KEY=xxx

# ============================================
# 2. 搜索工具配置（中国网络环境优化）
# ============================================

# 博查 AI搜索（推荐，中文内容优化）
BOCHA_ENABLED=true
BOCHA_API_KEY=your_bocha_api_key  # 获取: https://open.bochaai.com

# 🆕 v7.160: 博查 AI Search 增强配置
BOCHA_AI_SEARCH_ENABLED=true    # 启用AI Search API（结构化摘要）
BOCHA_IMAGE_SEARCH_ENABLED=true # 启用图片搜索
BOCHA_USE_DEEPSEEK_R1=true      # 搜索模式使用DeepSeek-R1推理

# 🆕 v7.162: TikHub 社交媒体搜索（抖音/小红书）
# 获取API密钥: https://user.tikhub.io
# 支持平台: xiaohongshu(小红书), douyin(抖音), weibo(微博), zhihu(知乎)
# 注: wechat_channels(微信视频号) API需要特殊权限，暂不支持
BOCHA_TIKHUB_ENABLED=false                    # 是否启用社交媒体搜索
BOCHA_TIKHUB_API_KEY=your_tikhub_api_key      # TikHub API密钥
BOCHA_TIKHUB_BASE_URL=https://api.tikhub.io   # 海外服务器 | https://api.tikhub.dev 中国大陆
BOCHA_TIKHUB_PLATFORMS=xiaohongshu,douyin,weibo,zhihu  # 启用的平台
BOCHA_TIKHUB_COUNT=5                          # 每个平台返回的结果数量

# DeepSeek API（R1推理模型，用于搜索模式深度分析）
DEEPSEEK_API_KEY=your_deepseek_api_key  # 获取: https://platform.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Tavily 搜索（国际搜索补充，免费1000次/月）
TAVILY_ENABLED=true
TAVILY_API_KEY=your_tavily_key  # 获取: https://tavily.com

# Serper 搜索（基于Google，中国网络可能不稳定）
SERPER_ENABLED=false
SERPER_API_KEY=your_serper_api_key  # 获取: https://serper.dev

# 🆕 v7.237: 专业搜索质量优化配置
ENABLE_DESIGN_PROFESSIONAL_MODE=true         # 启用专业设计搜索模式
MIN_SEARCH_RELEVANCE=0.75                    # 提升搜索相关性阈值（默认0.6）
PRIORITIZE_CASE_STUDIES=true                 # 优先返回案例研究类内容
ENHANCE_SCENARIO_KEYWORDS=true               # 增强场景化关键词生成
FILTER_COMMERCIAL_CONTENT=true               # 过滤纯商业推广内容

# ============================================
# 3. 雷达图动态维度配置（v7.142新增）
# ============================================

# 动态维度生成（智能分析用户需求，自动生成定制化维度）
# true: 启用LLM覆盖度分析，必要时生成新维度（推荐，响应时间+5-10秒）
# false: 仅使用静态维度库（快速，<1秒完成）
USE_DYNAMIC_GENERATION=true

# 智能维度学习（基于历史数据优化维度选择）
# true: 启用历史数据学习（响应时间+30-70秒，需Redis）
# false: 禁用学习功能（推荐，性能最优）
ENABLE_DIMENSION_LEARNING=false

# 强制生成模式（测试用，跳过覆盖度分析直接生成）
FORCE_GENERATE_DIMENSIONS=false

# 动态维度生成使用的LLM模型
DIMENSION_LLM_MODEL=gpt-4o-mini

# ============================================
# 4. 智能问卷生成配置（v7.142新增）
# ============================================

# LLM智能问卷生成（根据用户需求动态生成针对性问题）
# true: 启用LLM生成问卷（推荐，问题更精准，+3-5秒）
# false: 使用硬编码问题模板（快速，但通用性较差）
USE_LLM_GAP_QUESTIONS=true

# 专家视角风险预判（提前预测需要哪些专家角色，生成专家导向问题）
# true: 启用专家视角分析（+2-3秒，问题更专业）
# false: 禁用专家视角（快速模式）
ENABLE_EXPERT_FORESIGHT=true

# 问卷生成使用的LLM模型
QUESTIONNAIRE_LLM_MODEL=gpt-4o-mini

# ============================================
# 5. 分析质量评估配置（v7.234新增）
# ============================================

# 质量达标阈值（0-100，建议55-80）
# 低于此阈值会触发一次轻量级优化
ANALYSIS_QUALITY_THRESHOLD=55

# 是否启用迭代优化（低分时自动补充实体和关键词）
# true: 启用优化（推荐，+2-4秒，成本增加约0.5次LLM调用/请求）
# false: 禁用优化（快速模式，接受较低质量分析）
ANALYSIS_REFINE_ENABLED=true

# 优化使用的模型（建议使用chat模型控制成本）
ANALYSIS_REFINE_MODEL=deepseek-chat

# 前端是否显示具体分数（true显示82/100，false只显示等级A/B/C）
ANALYSIS_SHOW_SCORE=false

# ============================================
# 5. 搜索结果质量筛选配置（v7.212新增）
# ============================================

# 搜索结果质量评分阈值（0-1，低于此分数的结果不展示）
# 0.2: 宽松（保留更多可能相关的结果）
# 0.3: 平衡（推荐）
# 0.5: 严格（只保留高度相关内容）
SEARCH_QUALITY_THRESHOLD=0.3

# 是否启用LLM二次过滤（在反思阶段对搜索结果进行相关性判断）
# true: 启用（更精准，每轮+1-2秒）
# false: 仅使用规则评分（更快）
SEARCH_QUALITY_LLM_FILTER=true

# 每轮搜索最少需要的高质量来源数（不足则自动补充搜索）
SEARCH_MIN_QUALITY_SOURCES=3

# 补充搜索最大次数（防止无限循环）
SEARCH_SUPPLEMENT_MAX_RETRIES=3

# ============================================
# 6. 数据库配置
# ============================================

# PostgreSQL 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/project_analyzer

# Redis 缓存（会话管理、历史数据）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Milvus 向量数据库（知识库）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# ============================================
# 5. 前端配置
# ============================================

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Intelligent Project Analyzer

# ============================================
# 6. 日志和监控
# ============================================

LOG_LEVEL=INFO
ENABLE_DEBUG_LOGS=false

# Sentry 错误监控（可选）
# SENTRY_DSN=your_sentry_dsn

# ============================================
# 7. 其他配置
# ============================================

# 系统环境
NODE_ENV=development
# 运行环境: dev/development (开发), staging/test (测试), prod/production (生产)
ENVIRONMENT=dev

# CORS 允许的源
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT 密钥（用于用户认证）
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# 文件上传限制
MAX_UPLOAD_SIZE=10485760  # 10MB
