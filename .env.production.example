# 环境配置示例 - 生产环境
# 复制此文件为 .env.production 并根据需要修改

# ========================================
# 环境配置
# ========================================
ENVIRONMENT=production

# ========================================
# 日志配置
# ========================================

# 日志级别: INFO（生产环境推荐）
LOG_LEVEL=INFO

# 结构化日志（生产环境推荐开启）
STRUCTURED_LOGGING=true

# 详细日志（生产环境默认关闭）
ENABLE_DETAILED_LOGGING=false

# 日志采样率（生产环境建议10%）
LOG_SAMPLE_RATE=0.1

# ========================================
# 监控配置
# ========================================

# 启用监控
ENABLE_MONITORING=true

# 慢查询阈值（秒）
SLOW_QUERY_THRESHOLD=3.0

# ========================================
# 安全配置
# ========================================

# 确保在生产环境中设置真实的API密钥
# 不要在代码中硬编码密钥！
TAVILY_API_KEY=${TAVILY_API_KEY}

# Serper搜索配置 (v7.130+, 推荐使用)
SERPER_ENABLED=${SERPER_ENABLED:-true}
SERPER_API_KEY=${SERPER_API_KEY}

BOCHA_API_KEY=${BOCHA_API_KEY}
ARXIV_API_KEY=${ARXIV_API_KEY}

# ========================================
# Milvus 向量数据库知识库配置 (v7.141+)
# ========================================

# 启用 Milvus 知识库 (生产环境推荐)
MILVUS_ENABLED=${MILVUS_ENABLED:-true}

# Milvus 服务器配置 (生产环境使用环境变量)
MILVUS_HOST=${MILVUS_HOST:-localhost}
MILVUS_PORT=${MILVUS_PORT:-19530}

# Collection 配置
MILVUS_COLLECTION_NAME=${MILVUS_COLLECTION_NAME:-design_knowledge_base}

# Embedding 模型配置
MILVUS_EMBEDDING_MODEL=${MILVUS_EMBEDDING_MODEL:-BAAI/bge-m3}
MILVUS_EMBEDDING_DIM=${MILVUS_EMBEDDING_DIM:-1024}

# 检索配置
MILVUS_SIMILARITY_THRESHOLD=${MILVUS_SIMILARITY_THRESHOLD:-0.6}
MILVUS_CANDIDATE_MULTIPLIER=${MILVUS_CANDIDATE_MULTIPLIER:-5}

# Reranker 配置 (生产环境推荐开启)
MILVUS_RERANK_ENABLED=${MILVUS_RERANK_ENABLED:-true}
MILVUS_RERANKER_MODEL=${MILVUS_RERANKER_MODEL:-BAAI/bge-reranker-v2-m3}
MILVUS_RERANK_WEIGHT=${MILVUS_RERANK_WEIGHT:-0.7}

# 去重配置
MILVUS_DEDUP_THRESHOLD=${MILVUS_DEDUP_THRESHOLD:-0.95}

# 性能配置
MILVUS_TIMEOUT=${MILVUS_TIMEOUT:-30}
MILVUS_BATCH_SIZE=${MILVUS_BATCH_SIZE:-32}

# ========================================
# 性能配置
# ========================================

# Redis配置
REDIS_HOST=${REDIS_HOST:-localhost}
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_DB=${REDIS_DB:-0}
REDIS_PASSWORD=${REDIS_PASSWORD}

# 数据库连接池
DB_POOL_SIZE=20

# ========================================
# LLM维度推荐器配置 (v7.138+)
# ========================================

# 启用LLM维度推荐器（生产环境可选，需要充分测试后再开启）
# true: 启用LLM推荐（需要LLM服务稳定可用，建议先在staging环境测试）
# false: 禁用LLM推荐，仅使用规则引擎（默认，保守策略）
# 功能：使用LLM深度理解用户需求，推荐雷达图维度，提升准确率从85%到95%
ENABLE_LLM_DIMENSION_RECOMMENDER=${ENABLE_LLM_DIMENSION_RECOMMENDER:-false}

# ========================================
# 雷达图维度智能选择配置 (v7.147+)
# ========================================

# 启用智能维度学习（生产环境推荐开启）
# true: 使用 AdaptiveDimensionGenerator，基于历史数据学习优化维度选择
# false: 使用传统 RuleEngine，从 YAML 配置文件加载静态维度
# 性能影响：最小（历史数据在后台线程加载，10秒超时）
# 功能：
#   - 从 Redis 加载历史维度使用数据
#   - 自动检测特殊场景（极端环境、医疗需求、文化深度等）
#   - 学习用户偏好模式，持续优化维度选择
#   - 提升维度相关性和用户满意度
# 依赖：需要 Redis 运行（如果 Redis 不可用，自动降级到 RuleEngine）
# 建议：在 staging 环境测试 1-2 周后再在生产环境启用
ENABLE_DIMENSION_LEARNING=${ENABLE_DIMENSION_LEARNING:-true}

# 启用LLM动态维度生成（生产环境不推荐）
# true: 使用 DynamicDimensionGenerator，LLM 实时分析用户输入生成自定义维度
# false: 不使用 LLM 动态生成（推荐，避免延迟和成本）
# 性能影响：高（每次问卷增加 2-5 秒 LLM 调用延迟，增加 token 成本）
# 功能：
#   - LLM 深度分析用户需求
#   - 为独特/复杂项目生成定制维度
#   - 覆盖维度库中不存在的场景
# 建议：生产环境保持关闭，仅在 ENABLE_DIMENSION_LEARNING 无法满足需求时考虑启用
USE_DYNAMIC_GENERATION=${USE_DYNAMIC_GENERATION:-false}

# 强制维度生成模式（生产环境禁用）
# true: 强制使用动态生成，忽略其他配置
# false: 正常模式（生产环境必须为 false）
# 用途：仅用于测试/演示，生产环境严禁开启
FORCE_GENERATE_DIMENSIONS=${FORCE_GENERATE_DIMENSIONS:-false}

DB_MAX_OVERFLOW=10
