# 环境配置示例 - 测试环境
# 复制此文件为 .env.test 并根据需要修改
# 测试环境用于验证代码变更，与开发/生产环境并行运行

# ========================================
# 环境配置
# ========================================
ENVIRONMENT=test

# ========================================
# 服务端口配置（避免与开发环境冲突）
# ========================================
# 后端API端口（开发环境使用8000）
API_PORT=8100

# 前端端口（开发环境使用3001）
FRONTEND_PORT=3101

# ========================================
# 日志配置
# ========================================

# 日志级别: INFO（测试环境推荐）
LOG_LEVEL=INFO

# 结构化日志（JSON格式，便于自动化测试解析）
STRUCTURED_LOGGING=true

# 详细日志（测试环境启用以便调试）
ENABLE_DETAILED_LOGGING=true

# 日志采样率（测试环境全量记录）
LOG_SAMPLE_RATE=1.0

# 日志文件路径（与dev/prod隔离）
LOG_FILE_PATH=logs/test_server.log

# ========================================
# 数据库配置（隔离）
# ========================================

# SQLite路径（测试环境使用独立数据库）
DATABASE_URL=sqlite:///./data/test/archived_sessions.db

# Redis配置（使用独立DB索引）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1  # 测试环境使用DB 1（开发环境使用DB 0）
REDIS_PASSWORD=

# 或启用内存模式（推荐测试环境，避免残留数据）
REDIS_MEMORY_ONLY=true

# ========================================
# 监控配置
# ========================================

# 启用监控
ENABLE_MONITORING=true

# 慢查询阈值（秒）
SLOW_QUERY_THRESHOLD=2.0

# ========================================
# 搜索工具配置
# ========================================

# 测试环境可使用Mock数据避免实际API调用
USE_MOCK_SEARCH=false

# 如需使用真实API，配置以下密钥
# TAVILY_API_KEY=${TAVILY_API_KEY}
# BOCHA_API_KEY=${BOCHA_API_KEY}
# SERPER_API_KEY=${SERPER_API_KEY}

# ========================================
# LLM配置
# ========================================

# 测试环境可使用更便宜的模型
OPENAI_DEFAULT_MODEL=gpt-4o-mini
DIMENSION_LLM_MODEL=gpt-4o-mini
QUESTIONNAIRE_LLM_MODEL=gpt-4o-mini

# ========================================
# 功能开关（测试环境可安全测试新特性）
# ========================================

# 动态维度生成
USE_DYNAMIC_GENERATION=true
USE_PROJECT_SPECIFIC_DIMENSIONS=true

# 智能问卷生成
USE_LLM_GAP_QUESTIONS=true
ENABLE_EXPERT_FORESIGHT=true

# Smart Node Self-Skip（影子模式观测）
ENABLE_SMART_NODE_SELF_SKIP=false
ENABLE_SMART_NODE_SELF_SKIP_SHADOW=true

# 4步骤搜索流程（实验性功能）
ENABLE_4STEP_FLOW=false

# ========================================
# 性能配置
# ========================================

# 分析质量阈值（测试环境可适当降低）
ANALYSIS_QUALITY_THRESHOLD=50

# 搜索质量阈值
SEARCH_QUALITY_THRESHOLD=0.3

# ========================================
# CORS配置
# ========================================
CORS_ORIGINS=http://localhost:3101,http://localhost:3100

# ========================================
# 测试专用配置
# ========================================

# 启用测试模式（跳过某些耗时操作）
TEST_MODE=true

# 快速启动（跳过非必要初始化）
FAST_STARTUP=true

# 模拟延迟（ms，用于测试超时处理）
MOCK_DELAY=0
