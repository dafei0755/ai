{
  "uid": "llm-stats",
  "title": "LLM Statistics",
  "tags": ["llm", "statistics", "ai"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d", "90d", "1y"]
  },
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "24小时",
          "value": "now-24h"
        },
        "hide": 0,
        "includeAll": false,
        "label": "时间范围",
        "multi": false,
        "name": "timeRange",
        "options": [
          {"selected": false, "text": "1小时", "value": "now-1h"},
          {"selected": false, "text": "6小时", "value": "now-6h"},
          {"selected": false, "text": "12小时", "value": "now-12h"},
          {"selected": true, "text": "24小时", "value": "now-24h"},
          {"selected": false, "text": "本周", "value": "now/w"},
          {"selected": false, "text": "本月", "value": "now/M"},
          {"selected": false, "text": "本年", "value": "now/y"}
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "LLM 调用日志",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"intelligent_project_analyzer\", log_type=\"server\"} |~ \"(?i)GPT|openai|anthropic|claude|gemini|chat_model|llm_call|Vision API|OpenRouter\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "title": "LLM 调用次数 (每小时)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"intelligent_project_analyzer\", log_type=\"server\"} |~ \"(?i)GPT|openai|anthropic|claude|gemini|OpenRouter\" [1h])",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 500}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Token 相关日志 (每小时)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"intelligent_project_analyzer\", log_type=\"server\"} |~ \"(?i)model|chat_model|completion\" [1h])",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "purple", "value": null}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "LLM 错误 (每小时)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"intelligent_project_analyzer\", log_type=\"server\"} |~ \"(?i)GPT|openai|claude\" |~ \"(?i)error|failed|exception\" [1h])",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "LLM 调用趋势",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"intelligent_project_analyzer\", log_type=\"server\"} |~ \"(?i)GPT|openai|anthropic|claude|gemini|OpenRouter\" [5m])",
          "legendFormat": "LLM 调用",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    }
  ]
}
