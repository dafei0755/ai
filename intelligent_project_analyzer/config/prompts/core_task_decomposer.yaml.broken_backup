business_config:
  enable_dynamic_datetime: false
  timeout_seconds: 30
  # 🆕 v7.997: 任务数量提升30%，支持更深度的任务拆解
  adaptive_task_count: true  # 启用智能任务数量评估
  min_tasks: 8   # 绝对最小值（简单需求，v7.997: 6→8, +33%）
  max_tasks: 52  # 绝对最大值（超大型项目，v7.997: 40→52, +30%）
  base_tasks: 13 # 基准值（中等复杂度，v7.997: 10→13, +30%）
