        ],
        "target_audience": "业主本人（35岁单身女性）"
      }
    },
    "mission_3_task_dimensions": {
      "content": {
        "task_type": "design",
        "complexity_level": "complex",
        "solution_approach": "品牌DNA解析 → 用户画像构建 → 空间功能规划 → 色彩材质方案 → 家具软装配置 → 细节设计深化",
        "key_steps": [
